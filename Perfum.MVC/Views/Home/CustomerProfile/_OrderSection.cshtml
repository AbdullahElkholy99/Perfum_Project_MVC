@using System.Security.Claims
@model OrderVM
@{
    var customerName = User.FindFirst(ClaimTypes.Name)?.Value;
    var customerId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

}

<style>
    /* ===== Orders Card ===== */
    #tab-orders {
        background: var(--surface);
        border-radius: 14px;
        border: 1px solid var(--border);
        box-shadow: 0 8px 25px var(--shadow);
        padding: 18px;
    }

    /* ===== Header ===== */
    .card-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .card-title {
        font-size: 18px;
        font-weight: 600;
        color: var(--text);
    }

        .card-title span {
            color: var(--accent);
        }

    .card-action {
        background: var(--accent);
        color: #fff;
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        cursor: pointer;
        transition: .25s;
    }

        .card-action:hover {
            background: var(--accent2);
        }

    /* ===== Order Meta ===== */
    .card-meta-date {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        font-size: 13px;
        margin-bottom: 15px;
        color: var(--text2);
    }

    .order-id {
        font-weight: 600;
        color: var(--text);
    }

    .order-date {
        color: var(--text3);
    }

    .order-shippingAddress {
        color: var(--text2);
    }

    /* ===== Status Badge ===== */
    .order-status {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 20px;
        background: rgba(122,158,126,0.15);
        color: var(--green);
    }

    .status-dot {
        width: 6px;
        height: 6px;
        background: var(--green);
        border-radius: 50%;
    }

    /* ===== Order Items ===== */
    .order {
        padding: 14px 0;
        border-top: 1px solid var(--border);
    }

    .order-item {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    /* ===== Product Image ===== */
    .order-thumb {
        width: 50px;
        height: 50px;
        background: var(--surface2);
        border-radius: 10px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--border);
    }

        .order-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* ===== Product Info ===== */
    .order-info {
        flex: 1;
    }

    .order-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
    }

    .order-meta {
        font-size: 12px;
        color: var(--text3);
        margin-top: 2px;
    }

    .order-meta-sep {
        margin: 0 4px;
    }

    /* ===== Right Side ===== */
    .order-right {
        text-align: right;
    }

    .order-price {
        font-weight: 600;
        color: var(--accent2);
        margin-bottom: 4px;
    }

    /* ===== Reorder Button ===== */
    .order-reorder {
        border: 1px solid var(--accent);
        background: var(--surface2);
        color: var(--accent2);
        padding: 4px 10px;
        font-size: 12px;
        border-radius: 6px;
        cursor: pointer;
        transition: .25s;
    }

        .order-reorder:hover {
            background: var(--accent);
            color: #fff;
            box-shadow: 0 4px 10px var(--glow);
        }

    /* ===== Divider ===== */
    #tab-orders hr {
        border: none;
        border-top: 3px solid var(--border);
        margin-top: 12px;
        
    }
</style>


<div class="section-card tab-panel" id="tab-orders">
    <div class="card-head">
        <div class="card-title">Recent <span>Orders</span></div>
    </div>
    <div class="card-body"  >
        <div class="card-meta-date" id="orderMetaData"></div>
        <div class="card-body" id="orderItems"></div>
        <hr />
    </div>


</div>


<script>
    console.log("INside order  tab")

    async function LoadOrders() {

        try {

        const response = await fetch(`/Home/GetOrderByCustomerId`);

        if (!response.ok) {
            throw new Error("Failed to load orders");
        }

        const data = await response.json();

        const orderItems = document.getElementById("orderItems");
        const orderMetaData = document.getElementById("orderMetaData");

        orderMetaData.innerHTML = `
           <div class="order-id">Order #${data.id}</div>
               <div class="order-date">${new Date(data.date).toLocaleDateString()}</div>
               <div class="order-shippingAddress">${data.shippingAddress}</div>
                <span class="order-status os-delivered">
                    <span class="status-dot"></span>
                    ${data.status}
                </span>
        `;

        orderItems.innerHTML = data.orderItemsWithProduct.map(item => `
            <div class="order">
            
                <div class="order-item">
                    <div class="order-thumb"><img src="/${item.productImage}"/></div>

                    <div class="order-info">
                        <div class="order-name">${item.productName}</div>

                        <div class="order-meta">
                            <span>${item.sizeML} ML - </span>
                            <span>Qnt:${item.quantity}</span>
                            <span class="order-meta-sep">·</span>
                            <span class="order-meta-sep">·</span>
                        </div>
                    </div>

                    <div class="order-right">
                        <div class="order-price">$${item.unitPrice}</div>
                    </div>
                </div>
            </div>
        `).join("");

    }
    catch(err){
        console.error(err);
    }

    }

    LoadOrders();


</script>

