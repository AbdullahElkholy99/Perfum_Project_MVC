
<link href="~/css/users/herosectionhomepage.css" rel="stylesheet" />
<script src="~/js/users/herosectionhomepage.js"></script>

<!-- Custom cursor -->
<div class="cursor" id="cursor">
    <div class="cursor-ring" id="cursorRing"></div>
    <div class="cursor-dot" id="cursorDot"></div>
</div>

<!-- Theme toggle -->
<div class="theme-btn" id="themeBtn" onclick="toggleTheme()" title="Toggle theme">🌙</div>


<!-- Season pill -->
<div class="season-pill">
    <div class="sp-dot"></div>
    <div class="sp-text">New Season · Spring 2026</div>
</div>

<!-- HERO -->
<section class="hero">

    <div class="hero-wash"></div>
    <div class="hero-grain"></div>
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>
    <div class="orb orb3"></div>
    <canvas id="particles"></canvas>

    <!-- Deco -->
    <div class="deco">
        <div class="deco-h" style="top:20%"></div>
        <div class="deco-h" style="bottom:18%"></div>
        <div class="deco-v" style="left:40%"></div>
        <div class="deco-arc" style="width:500px;height:500px;top:-15%;right:-8%;border-color:var(--border)"></div>
        <div class="deco-arc" style="width:280px;height:280px;bottom:0%;left:-6%;border-color:var(--border)"></div>
    </div>

    <!-- Motes -->
    <div class="mote mote1"></div>
    <div class="mote mote2"></div>
    <div class="mote mote3"></div>
    <div class="mote mote4"></div>

    <div class="hero-inner">

        <!-- LEFT COPY -->
        <div class="hero-copy">

            <div class="eyebrow">
                <div class="eyebrow-dash"></div>
                <div class="eyebrow-text">Eau de Parfum · Luxury Edition</div>
                <div class="eyebrow-dash"></div>
            </div>

            <h1 class="hero-title">
                <span class="tl">The Art of</span>
                <span class="tl"><em>Invisible</em></span>
                <span class="tl">Presence</span>
            </h1>

            <div class="hero-rule"></div>

            <p class="hero-sub">
                Each fragrance is a story told in air —<br>
                a trail of memory left in every room<br>
                you grace with your passing.
            </p>

            <div class="hero-actions">
                <button class="btn-cta">Explore the Collection</button>
                <div class="btn-ghost">
                    <div class="ghost-arrow">→</div>
                    Our Story
                </div>
            </div>

            <div class="trust-row">
                <div class="trust-item">
                    <div class="trust-val">148</div>
                    <div class="trust-label">Unique Scents</div>
                </div>
                <div class="trust-item">
                    <div class="trust-val">Free</div>
                    <div class="trust-label">Shipping $250+</div>
                </div>
                <div class="trust-item">
                    <div class="trust-val">30</div>
                    <div class="trust-label">Day Returns</div>
                </div>
                <div class="trust-item">
                    <div class="trust-val">★ 4.9</div>
                    <div class="trust-label">Avg. Rating</div>
                </div>
            </div>
        </div>

        <!-- RIGHT VISUAL -->
        <div class="hero-visual" id="heroVisual">

            <div class="orbit-ring or1"></div>
            <div class="orbit-ring or2"></div>

            <!-- Floating info cards -->
            <div class="float-card fc-1">
                <div class="fc-label">Best Seller</div>
                <div class="fc-val">Oud Mystère</div>
                <div class="fc-stars">★★★★★</div>
                <div class="fc-sub">Oriental · 50ml</div>
            </div>

            <div class="float-card fc-2">
                <div class="fc-label">New Arrival</div>
                <div class="fc-val">Sakura Lumière</div>
                <div class="fc-sub">Floral · Spring 2026</div>
            </div>

            <div class="float-card fc-3">
                <div class="fc-label">Limited</div>
                <div class="fc-val">12 left</div>
                <div class="fc-sub">Rose Sauvage</div>
            </div>

            <!-- Main product card -->
            <div class="visual-card" id="visualCard">
                <div class="vc-glow"></div>

                <!-- Bottle -->
                <div class="bottle">
                    <div class="b-top"></div>
                    <div class="b-cap"></div>
                    <div class="b-neck"></div>
                    <div class="b-shoulder"></div>
                    <div class="b-body">
                        <div class="b-liquid"></div>
                        <div class="b-shine"></div>
                        <div class="b-shine2"></div>
                        <div class="b-label">
                            <span class="b-label-name">Sillage</span>
                            <span class="b-label-size">50ml · Edp</span>
                        </div>
                    </div>
                    <div class="b-reflection"></div>

                    <!-- Wisps -->
                    <div class="wisps">
                        <div class="wisp"></div>
                        <div class="wisp"></div>
                        <div class="wisp"></div>
                    </div>
                </div>

                <!-- Card info -->
                <div class="vc-info">
                    <div class="vc-season">Spring · Limited Edition</div>
                    <div class="vc-name">Nuit d'Ambre</div>
                    <div class="vc-tagline">Deep amber threaded with labdanum & tonka</div>
                    <div class="vc-notes">
                        <span class="vc-note">Cardamom</span>
                        <span class="vc-note">Rose</span>
                        <span class="vc-note">Amber</span>
                    </div>
                    <div class="vc-price-row">
                        <div class="vc-price">$210</div>
                        <button class="vc-add">+</button>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint">
        <div class="scroll-bar"></div>
        <div class="scroll-label">Scroll</div>
    </div>

</section>

<!-- Category strip -->
<div class="cat-strip">
    <div class="cs-item"><span class="cs-icon">🌸</span>Floral</div>
    <div class="cs-item"><span class="cs-icon">🔥</span>Oriental</div>
    <div class="cs-item"><span class="cs-icon">🌳</span>Woody</div>
    <div class="cs-item"><span class="cs-icon">❄️</span>Fresh</div>
    <div class="cs-item"><span class="cs-icon">🌿</span>Fougère</div>
    <div class="cs-item"><span class="cs-icon">🍂</span>Gourmand</div>
</div>
