@using System.Security.Claims
@{
    ViewData["Title"] = "My Profile";
    var userId = Convert.ToInt32(User.FindFirst(ClaimTypes.NameIdentifier)?.Value); 
    
    var userName = ViewBag.UserName as string ?? "User";
    var email = ViewBag.Email as string ?? "";
var imagePath = "/" + Convert.ToString(ViewBag.ImagePath);
Console.WriteLine($"********************* {userId}");
    Layout = "_HomeLayout";
}


<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sillage — My Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        .wish-img i {
            font-size: 40px;
            color: #c9a227;
        }

        .wish-remove i {
            font-size: 14px;
        }

        .notif-icon i {
            font-size: 18px;
            color: #c9a227;
            width: 22px;
            text-align: center;
        }
        /* ── TOKENS ── */
        :root[data-theme="light"] {
            --bg: #f7f3ef;
            --bg2: #ede7e0;
            --bg3: #e3d9cf;
            --surface: #ffffff;
            --surface2: #faf7f4;
            --border: rgba(160,130,100,0.16);
            --border2: rgba(160,130,100,0.28);
            --text: #2a1f14;
            --text2: #6b5040;
            --text3: #a08060;
            --accent: #c8854a;
            --accent2: #9b6b3a;
            --gold: #d4a844;
            --rose: #c97a7a;
            --green: #7a9e7e;
            --green-bg: rgba(122,158,126,.12);
            --shadow: rgba(100,70,40,0.08);
            --shadow2: rgba(100,70,40,0.16);
            --glow: rgba(200,133,74,0.13);
            --glow2: rgba(200,133,74,0.22);
        }

        :root[data-theme="dark"] {
            --bg: #0f0c09;
            --bg2: #1a1410;
            --bg3: #231b13;
            --surface: #1e1710;
            --surface2: #261e15;
            --border: rgba(200,150,80,0.12);
            --border2: rgba(200,150,80,0.22);
            --text: #f0e8da;
            --text2: #c8aa80;
            --text3: #8a6845;
            --accent: #e09a5a;
            --accent2: #c8854a;
            --gold: #e8c060;
            --rose: #d99090;
            --green: #90b894;
            --green-bg: rgba(144,184,148,.1);
            --shadow: rgba(0,0,0,0.3);
            --shadow2: rgba(0,0,0,0.55);
            --glow: rgba(224,154,90,0.1);
            --glow2: rgba(224,154,90,0.18);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
            overflow-x: hidden;
        }

        body {
            font-family: 'Jost', sans-serif;
            background: var(--bg);
            color: var(--text);
            font-weight: 300;
            min-height: 100vh;
            transition: background .4s, color .4s;
            overflow-x: hidden;
        }

        .snav-icon {
            width: 22px;
            margin-right: 10px;
            text-align: center;
            font-size: 16px;
        }
        /* ══════════ NAV ══════════ */
        nav {
            position: sticky;
            top: 0;
            z-index: 200;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(14px);
        }

        .nav-inner {
            max-width: 1320px;
            margin: 0 auto;
            padding: 0 32px;
            height: 68px;
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .nav-logo {
            font-family: 'Cormorant Garamond', serif;
            font-size: 24px;
            font-weight: 300;
            letter-spacing: .22em;
            color: var(--accent);
            cursor: pointer;
            flex-shrink: 0;
        }

            .nav-logo span {
                font-style: italic;
            }

        .nav-breadcrumb {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 11px;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--text3);
            margin-left: 16px;
        }

        .nav-breadcrumb-sep {
            opacity: .4;
        }

        .nav-breadcrumb-cur {
            color: var(--accent);
        }

        .nav-spacer {
            flex: 1;
        }

        .nav-icon-btn {
            width: 38px;
            height: 38px;
            border-radius: 9px;
            border: 1px solid var(--border);
            background: none;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 15px;
            color: var(--text3);
            transition: all .2s;
            position: relative;
        }

            .nav-icon-btn:hover {
                background: var(--bg2);
                color: var(--accent);
                border-color: var(--accent);
            }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            width: 17px;
            height: 17px;
            border-radius: 50%;
            background: var(--accent);
            color: #fff;
            font-size: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 500;
        }

        /* ══════════ PAGE LAYOUT ══════════ */
        .page-wrap {
            max-width: 1420px;
            margin: 0 auto;
            padding: 40px;
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 32px;
            align-items: start;
        }

        /* ══════════ SIDEBAR ══════════ */
        .sidebar {
            display: flex;
            flex-direction: column;
            gap: 20px;
            width:320px;
            margin-top: 25px;
        }

        /* ************************************ Profile Card ===== */
        .profile-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 22px;
            overflow: hidden;
            position: relative;
            box-shadow: 0 12px 35px var(--shadow);
            transition: .35s;
            animation: fadeUp .6s ease-out both;
        }

            .profile-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 18px 45px var(--shadow2);
            }

        /* ===== Header ===== */
        .profile-card-header {
            height: 110px;
            background: linear-gradient(135deg,var(--bg2),var(--bg3));
            position: relative;
            overflow: hidden;
        }

        /* decorative glow orbs */
        .pch-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(40px);
        }

        .pch-orb-1 {
            width: 140px;
            height: 140px;
            background: rgba(200,133,74,.18);
            top: -40px;
            left: -20px;
        }

        .pch-orb-2 {
            width: 90px;
            height: 90px;
            background: rgba(212,168,68,.12);
            bottom: -20px;
            right: 20px;
        }

        /* ===== Avatar ===== */
        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg,var(--accent),var(--gold));
            border: 3px solid var(--surface);
            font-family: 'Cormorant Garamond',serif;
            font-size: 26px;
            color: #fff;
            cursor: pointer;
            position: relative;
            transition: .3s;
            overflow: hidden;

        }
            .profile-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 50%;
                display: block;
            }

        /* edit icon */
        .avatar-edit {
            position: absolute;
            bottom: 5px;
            right: 4px;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--accent);
            color: #fff;
            font-size: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--surface);
            box-shadow: 0 4px 10px var(--shadow);
            transition: all .25s ease;
        }

            .avatar-edit:hover {
                background: linear-gradient(135deg, var(--accent), var(--gold));
                transform: scale(1.15);
                box-shadow: 0 4px 12px var(--shadow2);
            }
        /* ===== Card Body ===== */
        .profile-card-body {
            padding: 28px 24px 24px;
        }

        /* layout */
        .card-body-head {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
        }

        .profile-card-data {
            display: flex;
            flex-direction: column;
        }

        /* ===== Name ===== */
        .profile-name {
            font-family: 'Cormorant Garamond',serif;
            font-size: 22px;
            font-weight: 500;
            letter-spacing: .04em;
            color: var(--text);
            margin-left:20px;
        }

        .profile-email {
            font-size: 12px;
            color: var(--text3);
            letter-spacing: .05em;
            margin-top: 2px;
            margin-left: 20px;
        }

        /* ===== Tier Badge ===== */
        .profile-tier {
            margin-top: 10px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, rgba(212,168,68,.18), rgba(200,133,74,.12));
            border: 1px solid rgba(212,168,68,.3);
            border-radius: 99px;
            padding: 6px 14px;
            font-size: 10px;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--gold);
        }

        .tier-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--gold);
        }

        /* ===== Loyalty Section ===== */
        .loyalty-section {
            margin-top: 10px;
        }

        .loyalty-label {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: var(--text3);
            letter-spacing: .05em;
            margin-bottom: 8px;
        }

            .loyalty-label span {
                color: var(--accent);
                font-weight: 500;
            }

        /* progress bar */
        .loyalty-bar {
            height: 6px;
            background: var(--bg2);
            border-radius: 99px;
            overflow: hidden;
        }

        .loyalty-fill {
            height: 100%;
            width: 68%;
            background: linear-gradient(90deg,var(--accent),var(--gold));
            border-radius: 99px;
            animation: barFill .9s ease-out .4s both;
        }

        /* animation */
        @@keyframes barFill {
            from {
                width: 0
            }
        }

        /* next tier */
        .loyalty-next {
            margin-top: 6px;
            font-size: 10px;
            color: var(--text3);
        }

        /********************************************************* Sidebar nav */
        .sidebar-nav {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            animation: fadeUp .6s ease-out .1s both;
        }

        .snav-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 20px;
            cursor: pointer;
            transition: all .2s;
            border-bottom: 1px solid var(--border);
            font-size: 13px;
            color: var(--text2);
            letter-spacing: .04em;
            position: relative;
        }

            .snav-item:last-child {
                border-bottom: none;
            }

            .snav-item:hover {
                background: var(--bg2);
                color: var(--text);
            }

            .snav-item.active {
                background: var(--glow);
                color: var(--accent);
                border-right: 2px solid var(--accent);
            }

        .snav-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: var(--bg2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
            transition: background .2s;
        }

        .snav-item.active .snav-icon {
            background: var(--glow2);
        }

        .snav-badge {
            margin-left: auto;
            font-size: 10px;
            font-weight: 500;
            background: var(--accent);
            color: #fff;
            padding: 2px 8px;
            border-radius: 99px;
            letter-spacing: .04em;
        }

        .snav-badge-neutral {
            background: var(--bg3);
            color: var(--text3);
        }

        /* Sidebar quick stats */
        .sidebar-stats {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            animation: fadeUp .6s ease-out .2s both;
        }

        .ss-item {
            text-align: center;
        }

        .ss-num {
            font-family: 'Cormorant Garamond', serif;
            font-size: 24px;
            color: var(--accent);
            line-height: 1;
        }

        .ss-label {
            font-size: 10px;
            color: var(--text3);
            letter-spacing: .1em;
            text-transform: uppercase;
            margin-top: 3px;
        }

        .ss-divider {
            grid-column: 1/-1;
            height: 1px;
            background: var(--border);
        }

        /* ══════════ MAIN CONTENT ══════════ */
        .main-content {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* Section card */
        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            animation: fadeUp .6s ease-out both;
        }

            .section-card:nth-child(1) {
                animation-delay: .05s;
            }

            .section-card:nth-child(2) {
                animation-delay: .12s;
            }

            .section-card:nth-child(3) {
                animation-delay: .19s;
            }

            .section-card:nth-child(4) {
                animation-delay: .26s;
            }

        .card-head {
            padding: 22px 28px 18px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 20px;
            font-weight: 300;
            letter-spacing: .04em;
        }

            .card-title span {
                font-style: italic;
                color: var(--accent);
            }

        .card-action {
            font-size: 11px;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--accent);
            cursor: pointer;
            transition: color .2s;
            display: flex;
            align-items: center;
            gap: 6px;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 7px 14px;
            background: none;
            font-family: 'Jost', sans-serif;
        }

            .card-action:hover {
                background: var(--glow);
                border-color: var(--accent);
            }

        /* ── ORDERS ── */
        .card-body {
            padding: 20px 28px;
        }

        .order-item {
            display: grid;
            grid-template-columns: 56px 1fr auto;
            gap: 16px;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid var(--border);
            transition: background .15s;
        }

            .order-item:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

            .order-item:first-child {
                padding-top: 0;
            }

        .order-thumb {
            width: 56px;
            height: 56px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--bg2), var(--bg3));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
            border: 1px solid var(--border);
            overflow: hidden;
        }

            .order-thumb img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .order-info {
            min-width: 0;
        }

        .order-name {
            font-size: 14px;
            font-weight: 400;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 3px;
        }

        .order-meta {
            font-size: 11px;
            color: var(--text3);
            letter-spacing: .05em;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .order-meta-sep {
            opacity: .4;
        }

        .order-status {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 10px;
            letter-spacing: .1em;
            text-transform: uppercase;
            padding: 3px 10px;
            border-radius: 99px;
        }

        .status-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
        }

        .os-delivered {
            background: var(--green-bg);
            color: var(--green);
        }

            .os-delivered .status-dot {
                background: var(--green);
            }

        .os-transit {
            background: rgba(212,168,68,.14);
            color: var(--gold);
        }

            .os-transit .status-dot {
                background: var(--gold);
                animation: pulse 1.5s ease-in-out infinite;
            }

        .os-processing {
            background: rgba(200,133,74,.12);
            color: var(--accent);
        }

            .os-processing .status-dot {
                background: var(--accent);
            }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
                opacity: 1
            }

            50% {
                transform: scale(1.5);
                opacity: .6
            }
        }

        .order-right {
            text-align: right;
            flex-shrink: 0;
        }

        .order-price {
            font-family: 'Cormorant Garamond', serif;
            font-size: 18px;
            color: var(--text);
            margin-bottom: 6px;
        }

        .order-reorder {
            font-size: 10px;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--text3);
            cursor: pointer;
            transition: color .2s;
            padding: 4px 10px;
            border-radius: 7px;
            border: 1px solid var(--border);
            background: none;
            font-family: 'Jost', sans-serif;
        }

            .order-reorder:hover {
                color: var(--accent);
                border-color: var(--accent);
                background: var(--glow);
            }

        /* ── WISHLIST ── */
        .wishlist-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 16px;
            padding: 20px 28px;
        }

        .wish-card {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
            cursor: pointer;
            transition: all .28s cubic-bezier(.34,1.2,.64,1);
            position: relative;
        }

            .wish-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 14px 36px var(--shadow2);
                border-color: var(--border2);
            }

        .wish-img {
            height: 110px;
            background: linear-gradient(135deg, var(--bg2), var(--bg3));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            position: relative;
        }

        .wish-remove {
            position: absolute;
            top: 7px;
            right: 7px;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--surface);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: var(--text3);
            cursor: pointer;
            opacity: 0;
            transition: all .2s;
        }

        .wish-card:hover .wish-remove {
            opacity: 1;
        }

        .wish-remove:hover {
            background: rgba(201,122,122,.15);
            color: var(--rose);
            border-color: var(--rose);
        }

        .wish-body {
            padding: 10px 12px 12px;
        }

        .wish-name {
            font-size: 13px;
            font-weight: 400;
            color: var(--text);
            margin-bottom: 2px;
        }

        .wish-price {
            font-family: 'Cormorant Garamond', serif;
            font-size: 16px;
            color: var(--accent);
        }

        .wish-size {
            font-size: 10px;
            color: var(--text3);
            letter-spacing: .07em;
        }

        .wish-add {
            width: 100%;
            margin-top: 8px;
            padding: 8px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 10px;
            letter-spacing: .14em;
            text-transform: uppercase;
            cursor: pointer;
            transition: all .2s;
            font-family: 'Jost', sans-serif;
        }

            .wish-add:hover {
                background: var(--accent2);
            }

        /* ── PROFILE EDIT FORM ── */
        .form-grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 18px;
        }

        .form-grid-3 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 18px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

        .form-label {
            font-size: 10px;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--text3);
        }

        .form-input {
            padding: 12px 14px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 10px;
            font-family: 'Jost', sans-serif;
            font-size: 13px;
            color: var(--text);
            outline: none;
            transition: all .2s;
            letter-spacing: .03em;
        }

            .form-input:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px var(--glow);
            }

            .form-input::placeholder {
                color: var(--text3);
            }

        select.form-input {
            cursor: pointer;
            appearance: none;
        }

        .form-section-divider {
            grid-column: 1/-1;
            height: 1px;
            background: var(--border);
            margin: 4px 0;
        }

        .form-section-label {
            grid-column: 1/-1;
            font-size: 9px;
            letter-spacing: .28em;
            text-transform: uppercase;
            color: var(--accent);
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .form-section-label::after {
                content: '';
                flex: 1;
                height: 1px;
                background: linear-gradient(to right, var(--border), transparent);
            }

        /* Password field */
        .pw-wrap {
            position: relative;
        }

        .pw-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: var(--text3);
            font-size: 13px;
            transition: color .2s;
        }

            .pw-toggle:hover {
                color: var(--accent);
            }

        /* Save / cancel actions */
        .form-actions {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 20px 28px;
            border-top: 1px solid var(--border);
        }

        .btn-save {
            padding: 12px 28px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'Jost', sans-serif;
            font-size: 11px;
            letter-spacing: .18em;
            text-transform: uppercase;
            cursor: pointer;
            transition: all .28s;
            box-shadow: 0 5px 18px rgba(200,133,74,.28);
        }

            .btn-save:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 26px rgba(200,133,74,.38);
            }

        .btn-cancel {
            padding: 12px 22px;
            background: none;
            color: var(--text3);
            border: 1px solid var(--border);
            border-radius: 10px;
            font-family: 'Jost', sans-serif;
            font-size: 11px;
            letter-spacing: .18em;
            text-transform: uppercase;
            cursor: pointer;
            transition: all .2s;
        }

            .btn-cancel:hover {
                background: var(--bg2);
                color: var(--text);
            }

        .save-status {
            margin-left: auto;
            font-size: 11px;
            color: var(--green);
            letter-spacing: .06em;
            opacity: 0;
            transition: opacity .3s;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .save-status.show {
                opacity: 1;
            }

        /* ── SCENT PROFILE ── */
        .scent-notes-wrap {
            padding: 20px 28px;
        }

        .scent-row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 20px;
        }

        .scent-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 99px;
            font-size: 11px;
            letter-spacing: .1em;
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all .22s;
            background: var(--surface2);
            color: var(--text2);
            user-select: none;
        }

            .scent-tag:hover {
                border-color: var(--accent);
                color: var(--accent);
            }

            .scent-tag.selected {
                background: var(--glow);
                border-color: var(--accent);
                color: var(--accent);
            }

            .scent-tag .st-icon {
                font-size: 14px;
            }

        .scent-intensity {
            margin-top: 8px;
        }

        .si-label {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: var(--text3);
            letter-spacing: .07em;
            margin-bottom: 8px;
        }

            .si-label span {
                color: var(--accent);
            }

        .si-track {
            display: flex;
            gap: 6px;
        }

        .si-step {
            flex: 1;
            height: 6px;
            border-radius: 99px;
            background: var(--bg3);
            cursor: pointer;
            transition: background .2s;
        }

            .si-step.on {
                background: var(--accent);
            }

            .si-step:hover {
                background: var(--accent2);
            }

        /* ── ADDRESSES ── */
        .address-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            padding: 20px 28px;
        }

        .address-card {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 18px 20px;
            position: relative;
            transition: border-color .2s;
        }

            .address-card:hover {
                border-color: var(--border2);
            }

            .address-card.default {
                border-color: rgba(200,133,74,.35);
            }

        .addr-default-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            font-size: 9px;
            letter-spacing: .15em;
            text-transform: uppercase;
            background: var(--glow);
            color: var(--accent);
            border: 1px solid rgba(200,133,74,.25);
            border-radius: 99px;
            padding: 3px 9px;
        }

        .addr-name {
            font-size: 14px;
            font-weight: 400;
            color: var(--text);
            margin-bottom: 6px;
        }

        .addr-lines {
            font-size: 12px;
            line-height: 1.7;
            color: var(--text2);
            margin-bottom: 12px;
        }

        .addr-actions {
            display: flex;
            gap: 8px;
        }

        .addr-btn {
            font-size: 10px;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--text3);
            cursor: pointer;
            transition: color .2s;
            padding: 4px 10px;
            border-radius: 7px;
            border: 1px solid var(--border);
            background: none;
            font-family: 'Jost', sans-serif;
        }

            .addr-btn:hover {
                color: var(--accent);
                border-color: var(--accent);
            }

        .addr-btn-add {
            background: var(--surface2);
            border: 1px dashed var(--border);
            border-radius: 14px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 8px;
            cursor: pointer;
            transition: all .2s;
            color: var(--text3);
            font-size: 12px;
            letter-spacing: .08em;
        }

            .addr-btn-add:hover {
                border-color: var(--accent);
                color: var(--accent);
                background: var(--glow);
            }

        .addr-btn-add-icon {
            font-size: 24px;
            opacity: .5;
        }

        /* ── NOTIFICATION TOGGLES ── */
        .notif-list {
            padding: 6px 28px 22px;
        }

        .notif-item {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px 0;
            border-bottom: 1px solid var(--border);
        }

            .notif-item:last-child {
                border-bottom: none;
            }

        .notif-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: var(--bg2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .notif-info {
            flex: 1;
        }

        .notif-title {
            font-size: 13px;
            font-weight: 400;
            color: var(--text);
            margin-bottom: 2px;
        }

        .notif-desc {
            font-size: 11px;
            color: var(--text3);
            letter-spacing: .03em;
        }

        /* Toggle switch */
        .toggle-wrap {
            position: relative;
            width: 42px;
            height: 24px;
            flex-shrink: 0;
        }

            .toggle-wrap input {
                opacity: 0;
                width: 0;
                height: 0;
            }

        .toggle-slider {
            position: absolute;
            inset: 0;
            cursor: pointer;
            background: var(--bg3);
            border-radius: 99px;
            border: 1px solid var(--border);
            transition: .28s;
        }

            .toggle-slider::before {
                content: '';
                position: absolute;
                width: 16px;
                height: 16px;
                border-radius: 50%;
                background: var(--text3);
                left: 3px;
                bottom: 3px;
                transition: .28s;
            }

        .toggle-wrap input:checked + .toggle-slider {
            background: var(--accent);
            border-color: var(--accent);
        }

            .toggle-wrap input:checked + .toggle-slider::before {
                transform: translateX(18px);
                background: #fff;
            }

        /* ══════════ ANIMATIONS ══════════ */
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ══════════ TOAST ══════════ */
        .toast {
            position: fixed;
            bottom: 28px;
            right: 28px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px 20px;
            font-size: 13px;
            color: var(--text);
            box-shadow: 0 8px 32px var(--shadow2);
            z-index: 999;
            display: flex;
            align-items: center;
            gap: 10px;
            transform: translateY(80px);
            opacity: 0;
            transition: all .38s cubic-bezier(.34,1.2,.64,1);
            max-width: 300px;
        }

            .toast.show {
                transform: translateY(0);
                opacity: 1;
            }

        .toast-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--green);
            flex-shrink: 0;
        }

        /* ══════════ SCROLLBAR ══════════ */
        ::-webkit-scrollbar {
            width: 5px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }

        /* ══════════ RESPONSIVE ══════════ */
        @@media (max-width: 1000px) {
            .page-wrap {
                grid-template-columns: 1fr;
            }

            .sidebar {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 16px;
            }

            .profile-card {
                grid-column: 1/-1;
            }
        }

        @@media (max-width: 700px) {
            .page-wrap {
                padding: 24px 16px 60px;
                gap: 20px;
            }

            .sidebar {
                grid-template-columns: 1fr;
            }

            .card-body, .wishlist-grid, .scent-notes-wrap, .address-grid,
            .notif-list, .form-actions {
                padding-left: 18px;
                padding-right: 18px;
            }

            .card-head {
                padding: 18px 18px 14px;
            }

            .form-grid-2, .form-grid-3 {
                grid-template-columns: 1fr;
            }

            .address-grid {
                grid-template-columns: 1fr;
            }

            .wishlist-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .nav-breadcrumb {
                display: none;
            }

            .sidebar-stats {
                grid-template-columns: repeat(4, 1fr);
            }

            .ss-divider {
                display: none;
            }
        }
    </style>
</head>
<body>

    <!-- ══════════ PAGE ══════════ -->
    <div class="page-wrap">

        <!-- ── SIDEBAR ── -->
        <aside class="sidebar">

            <!-- Profile Card -->
            <div class="profile-card">
                <div class="profile-card-body">
                    <div class="card-body-head">
                         <div class="profile-avatar" title="Change photo">
                            <img src="@imagePath" alt="Image" />
                            <button class="avatar-edit" onclick="editImage()">
                                <i class="fas fa-pen"></i>
                            </button>
                        </div>
                        <div class="profile-card-data">
                            <div class="profile-name">@userName</div>
                            <div class="profile-email">@email</div>
                        </div>
                    </div>

                   
                </div>
            </div>

            <!-- Sidebar Navigation -->
            <nav class="sidebar-nav">

                <div class="snav-item active" onclick="showTab('orders', this)">
                    <div class="snav-icon">
                        <i class="fa-solid fa-box"></i>
                    </div>
                    My Orders
                </div>

                <div class="snav-item" onclick="showTab('profile', this)">
                    <div class="snav-icon">
                        <i class="fa-solid fa-user-pen"></i>
                    </div>
                    Edit Profile
                </div>

                <div class="snav-item" onclick="showTab('notifications', this)">
                    <div class="snav-icon">
                        <i class="fa-solid fa-bell"></i>
                    </div>
                    Notifications
                </div>

            </nav>
         
            <!-- Quick Stats -->
            <div class="sidebar-stats">
                <div class="ss-item">
                    <div class="ss-num">14</div>
                    <div class="ss-label">Orders</div>
                </div>
                <div class="ss-item">
                    <div class="ss-num">$1.8k</div>
                    <div class="ss-label">Spent</div>
                </div>
            </div>
        </aside>

        <!-- ── MAIN CONTENT ── -->
        <main class="main-content">

            <div id="modal-container"></div>

            <!-- ── ORDERS TAB ── -->
            @await Html.PartialAsync("~/Views/Home/CustomerProfile/_OrderSection.cshtml", null)

            <!-- ── PROFILE EDIT TAB ── -->
            @await Html.PartialAsync("~/Views/Home/CustomerProfile/_EditProfile.cshtml", null)
             
            <!-- ── NOTIFICATIONS TAB ── -->
            <div class="section-card tab-panel" id="tab-notifications" style="display:none">
                <div class="card-head">
                    <div class="card-title">Notification <span>Preferences</span></div>
                </div>

                <div class="notif-list">

                    <div class="notif-item">
                        <div class="notif-icon"><i class="fa-solid fa-box"></i></div>
                        <div class="notif-info">
                            <div class="notif-title">Order & Shipping Updates</div>
                            <div class="notif-desc">Track your orders in real-time from dispatch to delivery</div>
                        </div>
                        <label class="toggle-wrap"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                    </div>

                    <div class="notif-item">
                        <div class="notif-icon"><i class="fa-solid fa-star"></i></div>
                        <div class="notif-info">
                            <div class="notif-title">New Arrivals & Collections</div>
                            <div class="notif-desc">Be the first to discover new fragrances and seasonal launches</div>
                        </div>
                        <label class="toggle-wrap"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                    </div>

                    <div class="notif-item">
                        <div class="notif-icon"><i class="fa-solid fa-gift"></i></div>
                        <div class="notif-info">
                            <div class="notif-title">Exclusive Offers & Promotions</div>
                            <div class="notif-desc">Member-only discounts, gift-with-purchase, and seasonal sales</div>
                        </div>
                        <label class="toggle-wrap"><input type="checkbox"><span class="toggle-slider"></span></label>
                    </div>

                    <div class="notif-item">
                        <div class="notif-icon"><i class="fa-solid fa-heart"></i></div>
                        <div class="notif-info">
                            <div class="notif-title">Wishlist Restocks</div>
                            <div class="notif-desc">Get notified when a wishlisted item is back in stock</div>
                        </div>
                        <label class="toggle-wrap"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                    </div>

                    <div class="notif-item">
                        <div class="notif-icon"><i class="fa-solid fa-book-open"></i></div>
                        <div class="notif-info">
                            <div class="notif-title">The Sillage Journal</div>
                            <div class="notif-desc">Stories from the atelier, perfumer diaries, and fragrance guides</div>
                        </div>
                        <label class="toggle-wrap"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                    </div>

                    <div class="notif-item">
                        <div class="notif-icon"><i class="fa-solid fa-shield-halved"></i></div>
                        <div class="notif-info">
                            <div class="notif-title">Security Alerts</div>
                            <div class="notif-desc">Sign-in activity and account change notifications</div>
                        </div>
                        <label class="toggle-wrap"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                    </div>

                </div>

                <div class="form-actions">
                    <button class="btn-save" onclick="showToast('Notification preferences saved ✦')">
                        <i class="fa-solid fa-floppy-disk"></i> Save Preferences
                    </button>
                </div>
            </div>
        </main>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast">
        <div class="toast-dot"></div>
        <span id="toastMsg">Saved</span>
    </div>

    <script>
        /* ── THEME ── */
        let dark = false;
        function toggleTheme() {
          dark = !dark;
          document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
          document.getElementById('themeBtn').innerHTML = dark ? '<i class="fa-solid fa-sun"></i>' : '<i class="fa-solid fa-moon"></i>';
        }

        /* ── TAB SWITCHING ── */
        function showTab(id, navEl) {
          document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
          document.getElementById('tab-' + id).style.display = 'block';
          document.querySelectorAll('.snav-item').forEach(n => n.classList.remove('active'));
          navEl.classList.add('active');

        }

        //Done
        async function editImage() {

            const inputFileElement = document.createElement("input");
            inputFileElement.type = "file";
            inputFileElement.accept = "image/*";

            inputFileElement.addEventListener("change",async (event) => {
                const file = event.target.files[0];
                console.log(file);

                if(file){
                    // preview image
                    const preview = URL.createObjectURL(file);
                    document.querySelector(".profile-avatar img").src = preview;
                    
                    
                    
                    //Change image request
                    const formData = new FormData();
                    formData.append("id", userId); // name must match controller parameter
                    formData.append("ProfileImage", file); // name must match controller parameter

                    const response = await fetch(`/Home/UpdateProfileImage`, {
                        method: "POST",
                        body: formData
                    });

                    const result = await response.json();
                    console.log(result);
                    showToast('Profile saved successfully ');

                }
                else{
                  showToast('Profile saved successfully ');

                }
            });

            inputFileElement.click(); // يفتح نافذة اختيار الصورة
        }

    </script>
</body>
</html>

