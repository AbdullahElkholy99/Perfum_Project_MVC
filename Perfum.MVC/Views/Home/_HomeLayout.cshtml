@{
    ViewData["Title"] = "Home Page";
    Layout = null;
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
     var homeUrl = Url.Action("Index", "Home");

}

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sillage — Boutique</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <style>

        /* ── NAV ── */
        nav {
            position: fixed;
            z-index: 200;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(12px);
            width: 100%;
        }

        .nav-inner {
            max-width: 1320px;
            width: 100%;
            margin: auto;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 68px;
        }

            .nav-inner a {
                text-decoration: none;
                color: var(--text3);
                font-size: 14px;
            }

        .nav-logo {
            font-family: 'Cormorant Garamond',serif;
            font-size: 35px;
            font-weight: 900;
            letter-spacing: .22em;
            color: var(--accent);
            cursor: pointer;
            flex-shrink: 0;
            flex: 0 0 auto;
        }
      
            .nav-logo span {
                 font-style: italic;
                 font-size: 30px;
                 font-weight: 900;
            }

        .nav-links {
            display: flex;
            gap: 28px;
            justify-content: center;
            flex: 1;
            margin: 0 40px;
        }

        .nav-link {
            font-size: 12px;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--text3);
            cursor: pointer;
            transition: color .2s;
            padding: 4px 0;
            border-bottom: 1px solid transparent;
        }

            .nav-link:hover, .nav-link.active {
                color: var(--accent);
                border-bottom-color: var(--accent);
            }

        .nav-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            justify-content: flex-end;
            right: 0;
        }

        .nav-icon-btn {
            width: 38px;
            height: 38px;
            border-radius: 9px;
            border: 1px solid var(--border);
            background: none;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 16px;
            color: var(--text3);
            transition: all .2s;
            position: relative;
        }

        .nav-user {
            position: relative;
        }

        .user-menu {
            position: absolute;
            right: 0;
            top: 48px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            width: 180px;
            display: none;
            flex-direction: column;
            padding: 6px;
            box-shadow: 0 12px 30px rgba(0,0,0,.15);
            animation: menuFade .18s ease;
        }

            .user-menu a {
                padding: 10px 12px;
                text-decoration: none;
                color: var(--text2);
                font-size: 13px;
                border-radius: 8px;
                transition: .15s;
            }

                .user-menu a:hover {
                    background: var(--bg2);
                    color: var(--accent);
                }

            .user-menu hr {
                border: none;
                border-top: 1px solid var(--border);
                margin: 6px 4px;
            }

            .user-menu.show {
                display: flex;
            }

        @@keyframes menuFade {
            from {
                opacity: 0;
                transform: translateY(-6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .nav-icon-btn:hover {
            background: var(--bg2);
            color: var(--accent);
            border-color: var(--accent);
            transform: translateY(-1px);
        }

        .nav-icon-btn i {
            font-size: 16px;
            pointer-events: none;
        }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--accent);
            color: #fff;
            font-size: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 500;
            font-family: 'Jost',sans-serif;
        }

        .theme-btn {
            font-size: 14px;
        }

        /* NAV TOGGLE */
        .nav-toggle {
            display: none;
            font-size: 20px;
            cursor: pointer;
            color: var(--text);
        }

        @@media (max-width:880px) {

            .nav-inner {
                padding: 0 20px;
            }
            .nav-toggle {
                display: block;
                margin-left: auto;
            }
            .nav-links {
                position: absolute;
                top: 68px;
                left: 0;
                right: 0;
                background: var(--surface);
                border-bottom: 1px solid var(--border);
                flex-direction: column;
                align-items: center;
                gap: 16px;
                padding: 20px;
                display: none;
            }

            .nav-links.open {
                display: flex;
            }

            .nav-inner{
                display:flex;
                justify-content:space-between;
                align-items:center;
            }

            .nav-actions {
                flex:1;
                justify-content: center;
            }
        }
    </style>

</head>
<body>
    @* ************************************************* Start NAV  ***********@

    <nav>
        <div class="nav-inner">
            <div class="nav-logo" onclick="scrollToShop()">
                <a asp-controller="Home" asp-action="Index" class="nav-logo-title">
                    <span>Sillage</span>
                </a>
            </div>
 
             <div class="nav-links" id="navLinks">

                <div class="nav-link active" onclick="setNavActive(this)">
                    <a href="@homeUrl#hero">Home</a>
                </div>

                <div class="nav-link" onclick="setNavActive(this)">
                    <a href="@homeUrl#shopSection">Products</a>
                </div>

                <div class="nav-link" onclick="setNavActive(this)">
                    <a href="@homeUrl#footer">Footer</a>
                </div>

                <div class="nav-link" onclick="setNavActive(this)">
                    <a href="@homeUrl#contactSection">ContactUs</a>
                </div>

                <div class="nav-link" onclick="setNavActive(this)">
                    <a href="@homeUrl#aboutUs">AboutUs</a>
                </div>

            </div>

            <div class="nav-actions">
                <div class="nav-icon-btn theme-btn" onclick="toggleTheme()" title="Toggle theme" id="themeBtn">
                    <i class="fa-solid fa-moon"></i>
                </div>
                @* <div class="nav-icon-btn" onclick="toggleWishlist()" title="Wishlist"><i class="fa-regular fa-heart"></i></div> *@
                <div class="nav-icon-btn" onclick="openCart()" title="Cart">
                    <i class="fa-solid fa-cart-arrow-down"></i>
                    <span class="cart-badge" id="cartBadge" style="display:none">0</span>
                </div>
                <!-- User Settings -->
                <div class="nav-user">
                    <div class="nav-icon-btn" onclick="toggleUserMenu()" title="Account">
                        <i class="fa-solid fa-user-gear"></i>

                    </div>

                    <div class="user-menu" id="userMenu">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Home" asp-action="Profile"><i class="fa-solid fa-address-card"></i> Profile</a>
                            <hr>
                            <a asp-controller="Account" asp-action="Logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login"><i class="fa-solid fa-arrow-right-to-bracket"></i> Login</a>
                            <a asp-controller="Account" asp-action="Register">
                                <i class="fa-solid fa-person-circle-plus"></i>
                                Register
                            </a>
                        }
                    </div>
                </div>

            </div>

            <div class="nav-toggle" onclick="toggleNav()">
                <i class="fas fa-bars"></i>
            </div>
        </div>


    </nav>
    @* ************************************************* End NAV  ***********@

    @RenderBody();

    <script>
         function toggleNav() {
            document.getElementById("navLinks").classList.toggle("open");
        }
        function toggleUserMenu() {
            const menu = document.getElementById("userMenu");
            menu.classList.toggle("show");
        }

        document.addEventListener("click", (e) => {
            const menu = document.getElementById("userMenu");
            if (!e.target.closest(".nav-user")) {
                menu.classList.remove("show");
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)


</body>
</html>
