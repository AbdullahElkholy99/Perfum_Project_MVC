

<style>
#ramadanOverlay{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#0a0618;transition:opacity .9s ease,visibility .9s ease;}
#ramadanOverlay.hide{opacity:0;visibility:hidden;pointer-events:none;}
.rm-sky{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,#1a0e3a 0%,transparent 65%),radial-gradient(ellipse 60% 50% at 20% 100%,#0d1a2e 0%,transparent 55%),linear-gradient(180deg,#06030f 0%,#0d0820 40%,#120a25 70%,#0a0618 100%);pointer-events:none;}
.rm-stars{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.rm-star{position:absolute;border-radius:50%;background:#fff;animation:rmStarTwinkle ease-in-out infinite;}
@@keyframes rmStarTwinkle{0%,100%{opacity:.15;transform:scale(1)}50%{opacity:1;transform:scale(1.4)}}
.rm-geo-top,.rm-geo-bottom{position:absolute;left:0;right:0;height:90px;pointer-events:none;overflow:hidden;}
.rm-geo-top{top:0}.rm-geo-bottom{bottom:0;transform:scaleY(-1);}
.rm-geo-svg{width:100%;height:100%;opacity:.55;}
.rm-moon-wrap{position:absolute;top:6%;left:50%;transform:translateX(-50%);animation:rmMoonFloat 5s ease-in-out infinite;filter:drop-shadow(0 0 28px rgba(212,168,68,.55)) drop-shadow(0 0 60px rgba(212,168,68,.25));}
@@keyframes rmMoonFloat{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(-10px)}}
.rm-mosque{position:absolute;bottom:82px;left:50%;transform:translateX(-50%);opacity:.22;pointer-events:none;}
.rm-mosque svg{width:min(520px,90vw);height:auto;}
.rm-lantern{position:absolute;bottom:90px;filter:drop-shadow(0 0 16px rgba(212,168,68,.5));}
.rm-lantern svg{width:52px;height:84px;}
.rm-l1{left:7%;animation:rmLSway 4.2s ease-in-out infinite 0s;}
.rm-l2{left:19%;animation:rmLSway 3.8s ease-in-out infinite -.6s;}
.rm-l3{right:7%;animation:rmLSway 4.5s ease-in-out infinite -.3s;}
.rm-l4{right:19%;animation:rmLSway 3.6s ease-in-out infinite -.9s;}
@@keyframes rmLSway{0%,100%{transform:rotate(-6deg)}50%{transform:rotate(6deg)}}
.rm-glow-rings{position:absolute;inset:0;pointer-events:none;}
.rm-glow-ring{position:absolute;border-radius:50%;border:1px solid rgba(212,168,68,.12);animation:rmRingExpand 3.5s ease-out infinite;top:50%;left:50%;width:300px;height:300px;}
.rm-glow-ring:nth-child(2){animation-delay:1.1s}.rm-glow-ring:nth-child(3){animation-delay:2.2s}
@@keyframes rmRingExpand{0%{transform:translate(-50%,-50%) scale(.6);opacity:.6}100%{transform:translate(-50%,-50%) scale(2.8);opacity:0}}
.rm-particles{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.rm-p{position:absolute;border-radius:50%;animation:rmPartFloat linear infinite;opacity:0;}
@@keyframes rmPartFloat{0%{opacity:0;transform:translateY(0)}10%{opacity:1}80%{opacity:.4}100%{opacity:0;transform:translateY(-100vh)}}
.rm-card{position:relative;z-index:5;text-align:center;padding:52px 64px 44px;border-radius:4px;border:1px solid rgba(212,168,68,.22);background:linear-gradient(160deg,rgba(212,168,68,.07) 0%,rgba(255,255,255,.02) 50%,rgba(212,168,68,.05) 100%);backdrop-filter:blur(6px);box-shadow:0 0 0 1px rgba(212,168,68,.1) inset,0 32px 80px rgba(0,0,0,.6);max-width:520px;width:90vw;animation:rmCardReveal 1s cubic-bezier(.16,1,.3,1) .3s both;}
@@keyframes rmCardReveal{from{opacity:0;transform:translateY(24px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.rm-card::before,.rm-card::after{content:'';position:absolute;width:22px;height:22px;border-color:rgba(212,168,68,.55);border-style:solid;}
.rm-card::before{top:10px;left:10px;border-width:1px 0 0 1px}.rm-card::after{bottom:10px;right:10px;border-width:0 1px 1px 0;}
.rm-ornament{font-size:11px;letter-spacing:.45em;text-transform:uppercase;color:rgba(212,168,68,.6);margin-bottom:20px;display:flex;align-items:center;justify-content:center;gap:14px;animation:rmFadeUp .8s ease-out .6s both;}
.rm-ornament-line{flex:1;height:1px;max-width:60px;background:linear-gradient(to right,transparent,rgba(212,168,68,.5),transparent);}
.rm-arabic{font-family:'Scheherazade New','Amiri','Traditional Arabic',serif;font-size:clamp(36px,7vw,58px);font-weight:400;line-height:1.3;letter-spacing:.02em;margin-bottom:10px;direction:rtl;animation:rmFadeUp .9s ease-out .7s both;background:linear-gradient(135deg,#e8c87a 0%,#d4a844 40%,#c8954a 80%,#e8c060 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.rm-english{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(22px,4vw,32px);font-weight:300;font-style:italic;color:rgba(232,200,122,.85);letter-spacing:.06em;margin-bottom:6px;animation:rmFadeUp .9s ease-out .82s both;}
.rm-tagline{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:rgba(212,168,68,.45);margin-bottom:28px;animation:rmFadeUp .9s ease-out .94s both;}
.rm-bar-wrap{width:100%;height:2px;background:rgba(212,168,68,.12);border-radius:99px;overflow:hidden;margin-bottom:18px;animation:rmFadeUp .6s ease-out 1.1s both;}
.rm-bar-fill{height:100%;width:100%;background:linear-gradient(to right,#c8854a,#d4a844,#e8c060);border-radius:99px;transform-origin:left;animation:rmBarDrain 3s linear .5s both;}
@@keyframes rmBarDrain{from{transform:scaleX(1)}to{transform:scaleX(0)}}
.rm-skip{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:rgba(212,168,68,.3);cursor:pointer;transition:color .25s;animation:rmFadeUp .6s ease-out 1.3s both;user-select:none;}
.rm-skip:hover{color:rgba(212,168,68,.7);}
@@keyframes rmFadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@@media(max-width:600px){.rm-card{padding:36px 28px 32px;}.rm-l2,.rm-l4{display:none;}}
</style>

