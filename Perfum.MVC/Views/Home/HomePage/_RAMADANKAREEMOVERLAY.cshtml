<!-- ══ END OVERLAY ══ -->

<script>
    (function () {

    var overlay = document.getElementById('ramadanOverlay');
    if (!overlay) return;

    // check if already shown
    if (localStorage.getItem("ramadanOverlayShown")) {
        overlay.style.display = "none";
        return;
    }

    document.body.style.overflow = 'hidden';

    setTimeout(function () {

        overlay.classList.add('hide');

        setTimeout(function () {

            document.body.style.overflow = '';
            overlay.style.display = 'none';

            // save in localStorage
            localStorage.setItem("ramadanOverlayShown", "true");

        }, 900);

    }, 3000);

})();
</script>