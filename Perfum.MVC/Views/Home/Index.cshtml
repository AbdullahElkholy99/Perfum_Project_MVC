@model PagedResult<ProductVM, ProductFilter, DashBoardProduct>
@{
    ViewData["Title"] = "Home Page";
    Layout = "_HomeLayout";
    Model.Filter ??= new ProductFilter();
    var products = Model?.Items ?? new List<ProductVM>();
    var totalCount = Model?.TotalCount ?? 0;
    var inStock = products.Count(p => p.Stock > 10);
    var lowStock = products.Count(p => p.Stock > 0 && p.Stock <= 10);
    var outOfStock = products.Count(p => p.Stock == 0);
}

 
    <link href="~/css/users/customerpage.css" rel="stylesheet" />
 
    @* ************************************************* Start hero section  ***********@

    @await Html.PartialAsync("~/Views/Home/HomePage/_Hero.cshtml")

    @* ************************************************* End Of Hero Section  ***********@

    @* ************************************************* Start SHOP  ***********@
    @await Html.PartialAsync("~/Views/Home/HomePage/_ShopSection.cshtml",Model)
    @* ************************************************* End SHOP  ***********@

    <!-- ── PRODUCT MODAL ── -->
    <div class="modal-bg" id="modalBg" onclick="closeProductModal(event)">
        <div class="prod-modal" id="prodModal">
            <div class="pm-hero" id="pmHero">
                <img id="pmHeroImg" alt="Product Image">
                <div class="pm-close" onclick="closeProductModal(true)">✕</div>
            </div>
            <div class="pm-body">
                <div class="pm-cat" id="pmCat"></div>
                <div class="pm-name" id="pmName"></div>
                <div class="pm-tagline" id="pmTagline"></div>
                <div class="pm-price-row">
                    <div class="pm-price" id="pmPrice"></div>
                    <div class="pm-size" id="pmSize"></div>
                </div>
                <div class="pm-section-title">Details</div>
                <div class="pm-details-row" id="pmDetails" style="margin-bottom:22px;"></div>
                <div class="pm-qty-row">
                    <button class="pm-add-btn" id="pmAddBtn">Add to Cart — <span id="pmTotal"></span></button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── CART DRAWER ── -->
    <div class="cart-backdrop" id="cartBg" onclick="closeCart()"></div>
    <div class="cart-drawer" id="cartDrawer">
        <div class="cart-head">
            <div class="cart-title">Your Cart <span id="cartCount" style="font-size:14px;color:var(--text3)"></span></div>
            <div class="cart-close" onclick="closeCart()">✕</div>
        </div>
        <div class="cart-items" id="cartItems"></div>
        <div class="cart-footer" id="cartFooter"></div>
    </div>


    <!-- ── CHECKOUT OVERLAY ── -->
    <div class="checkout-overlay" id="checkoutOverlay">
        <div class="co-nav">
            <div class="co-back" onclick="closeCheckout()">← Back to cart</div>
            <div class="co-logo">Sillage</div>
            <div class="co-steps" id="coSteps"></div>
        </div>
        <div class="co-body">
            <div class="co-right" id="coRight"></div>
            <div class="co-left" id="coLeft"></div>
        </div>
    </div>

    <!-- ── SUCCESS ── -->
    <div class="success-screen" id="successScreen">
        <div class="success-ring">✓</div>
        <div class="success-title">Order <em>Confirmed</em></div>
        <p class="success-sub">Thank you for your purchase. Your fragrances will be carefully packaged and dispatched within 24 hours. A confirmation has been sent to your email.</p>
        <div class="success-order-id" id="successOrderId">#5312</div>
        <div class="success-actions">
            <div class="hero-cta" onclick="continueShopping()">Continue Shopping</div>
            <div class="hero-cta" style="background:var(--surface);color:var(--accent);border:1.5px solid var(--accent);box-shadow:none;" onclick="continueShopping()">View Orders</div>
        </div>
    </div>

    <div class="toast" id="toast"><div class="toast-dot"></div><span id="toastMsg">Added to cart</span></div>


    @* ************************************************* Start contuctsus  ***********@

    @* @await Html.PartialAsync("~/Views/Home/HomePage/_ContactUs.cshtml") *@
    @* ************************************************* End contuctsus  *************@


    @* ************************************************* Start footer  ***********@

    @await Html.PartialAsync("~/Views/Home/HomePage/_Footer.cshtml")

    @* ************************************************* End footer  *************@


    @await Html.PartialAsync("~/Views/Home/HomePage/_RAMADANKAREEMOVERLAY.cshtml")

  
    @section Scripts{
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        window.isLoggedIn = @User.Identity.IsAuthenticated.ToString().ToLower();
        window.customerId = "@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value";

        console.log("isLoggedIn:", window.isLoggedIn);
        console.log("customerId:", window.customerId);
    </script>
    <script src="~/js/users/customerpage.js"></script>

    }
 