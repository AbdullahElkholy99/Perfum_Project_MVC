
@model PagedResult<OrderVM, OrderFilter, DashBoardOrder>

@{
    ViewData["Title"] = "Orders";
    Layout = "~/Views/Shared/_DashboardAdminLayOut.cshtml";
    var orders = Model?.Items ?? new List<Perfum.Services.ViewModels.OrderVM.OrderVM>();
    var totalCount = Model?.TotalCount ?? 0;
    var activeCount = orders.Count(o => o.Status == Status.Active);
    var inactiveCount = orders.Count(o => o.Status == Status.Inactive);
    var pendingCount = orders.Count(o => o.Status == Status.Pending);
    var expiredCount = orders.Count(o => o.Status == Status.Expired);
}

<link href="~/css/dashbord/order.css" rel="stylesheet" />

<div class="order-page"  >

    @* ── Header ── *@
    <div class="topbar">
        <div>
            <div class="page-title">Orders <span>Management</span></div>
            <div class="page-subtitle">@totalCount order@(totalCount == 1 ? "" : "s")</div>
        </div>
        <div class="topbar-actions">
            <button class="btn btn-ghost" onclick="showToast('Orders exported')">⬇ Export</button>
            <a asp-action="Create" class="btn btn-primary">✦ Add Order</a>
        </div>
    </div>

    @* ── Alerts ── *@
    @if (TempData["Success"] != null)
    {
        <div class="alert-success">✓ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-error">✕ @TempData["Error"]</div>
    }

    @* ── Stats ── *@
    <div class="stat-strip">
        <div class="mini-stat">
            <div class="mini-icon ic-amber">🛒</div>
            <div><div class="mini-val">@totalCount</div><div class="mini-label">Total Orders</div></div>
        </div>
        <div class="mini-stat">
            <div class="mini-icon ic-sage">✅</div>
            <div><div class="mini-val">@activeCount</div><div class="mini-label">Active</div></div>
        </div>
        <div class="mini-stat">
            <div class="mini-icon ic-gold">⏳</div>
            <div><div class="mini-val">@pendingCount</div><div class="mini-label">Pending</div></div>
        </div>
        <div class="mini-stat">
            <div class="mini-icon ic-rose">⊘</div>
            <div><div class="mini-val">@inactiveCount</div><div class="mini-label">Inactive</div></div>
        </div>
        <div class="mini-stat">
            <div class="mini-icon ic-dark">🕐</div>
            <div><div class="mini-val">@expiredCount</div><div class="mini-label">Expired</div></div>
        </div>
    </div>

    @* ── Toolbar ── *@
    <div class="toolbar">
        <div class="search-bar">
            <span style="color:var(--text3);font-size:16px">⌕</span>
            <input id="searchInput" placeholder="Search orders…" />
        </div>
        <select class="sort-select" id="sortSel"
                style="appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22><path fill=%22%23a08060%22 d=%22M0 0l5 6 5-6z%22/></svg>');background-repeat:no-repeat;background-position:right 12px center;padding-right:30px;">
            <option value="id">Order ID</option>
            <option value="date-desc">Date ↓ Newest</option>
            <option value="date-asc">Date ↑ Oldest</option>
            <option value="total-desc">Total ↓</option>
            <option value="total-asc">Total ↑</option>
        </select>
        <div class="view-toggle">
            <div class="view-btn active" id="gridViewBtn" onclick="switchView('grid')" title="Grid">⊞</div>
            <div class="view-btn" id="listViewBtn" onclick="switchView('list')" title="List">☰</div>
        </div>
    </div>

    @* ── Bulk bar ── *@
    <div class="bulk-bar" id="bulkBar">
        <div class="bulk-text">Selected: <strong id="bulkCount">0</strong></div>
        <button class="btn btn-ghost btn-sm" onclick="clearSelection()">Clear</button>
        <button class="btn btn-ghost btn-sm" onclick="showToast('Status updated')">Change Status</button>
        <button class="btn btn-danger btn-sm" onclick="bulkDelete()">✕ Delete</button>
    </div>

    @* ── Grid ── *@
    <div class="prod-grid" id="prodGrid">
        @foreach (var o in orders)
        {
            var statusClass = o.Status switch
            {
                Status.Active => "sb-in",
                Status.Pending => "sb-low",
                Status.Inactive => "sb-out",
                Status.Expired => "sb-out",
                _ => ""
            };
            <div class="prod-card"
                 data-id="@o.Id"
                 data-search="@((o.Id.ToString() + " " + (o.ShippingAddress ?? "") + " " + o.Status.ToString()).ToLowerInvariant())"
                 data-date="@(o.Date?.Ticks ?? 0)"
                 data-total="@o.TotalPrice">

                <div class="stock-badge @statusClass">@o.Status</div>

                <div class="prod-banner order-banner">
                    <span class="order-icon">🧾</span>
                </div>

                <div class="prod-body">
                    <div class="prod-category">Order · @(o.Date?.ToString("MMM dd, yyyy") ?? "—")</div>
                    <div class="prod-name">#@o.Id</div>
                    <div style="font-size:12px;color:var(--text3);margin-top:-2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        @(o.ShippingAddress ?? "No address")
                    </div>
                    <div class="prod-footer">
                        <div class="prod-price">$@o.TotalPrice.ToString("N2")</div>
                        <div>
                            <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-ghost btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-ghost btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@o.Id" class="btn btn-danger btn-sm">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
        @if (!orders.Any())
        {
            <div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--text3);">No orders found.</div>
        }
    </div>

    @* ── Table ── *@
    <div class="table-wrap hidden" id="tableWrap">
        <table class="prod-table">
            <thead>
                <tr>
                    <th style="width:32px">
                        <input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)"
                               style="accent-color:var(--accent);cursor:pointer;width:15px;height:15px;" />
                    </th>
                    <th>Order ID</th>
                    <th>Shipping Address</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var o in orders)
                {
                    var statusClass = o.Status switch
                    {
                        Status.Active => "sb-in",
                        Status.Pending => "sb-low",
                        Status.Inactive => "sb-out",
                        Status.Expired => "sb-out",
                        _ => ""
                    };
                    <tr data-search="@((o.Id.ToString() + " " + (o.ShippingAddress ?? "") + " " + o.Status.ToString()).ToLowerInvariant())"
                        data-date="@(o.Date?.Ticks ?? 0)"
                        data-total="@o.TotalPrice"
                        data-id="@o.Id">
                        <td>
                            <input type="checkbox" class="row-check"
                                   style="accent-color:var(--accent);cursor:pointer;width:15px;height:15px;" />
                        </td>
                        <td>
                            <div class="prod-identity">
                                <div class="prod-thumb" style="background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:18px;">🧾</div>
                                <div>
                                    <div class="pid-name">Order #@o.Id</div>
                                    <div class="pid-sku">@(o.Date?.ToString("MMM dd, yyyy HH:mm") ?? "—")</div>
                                </div>
                            </div>
                        </td>
                        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @(o.ShippingAddress ?? "—")
                        </td>
                        <td>@(o.Date?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td><span class="price-val">$@o.TotalPrice.ToString("N2")</span></td>
                        <td>
                            <span class="stock-badge @statusClass" style="position:static;font-size:11px;">@o.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-ghost btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-ghost btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@o.Id" class="btn btn-danger btn-sm">✕</a>
                        </td>
                    </tr>
                }
                @if (!orders.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center;padding:48px;color:var(--text3);">No orders found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ── Pagination ── *@
    <div class="pagination">
        <div class="page-info" id="pageInfo">Showing 1–@Math.Min(12, totalCount) of @totalCount</div>
        <div class="page-btns">
            <div class="page-btn">‹</div>
            <div class="page-btn active">1</div>
            <div class="page-btn">›</div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        (function () {

            /* ── View toggle ── */
            window.switchView = function (v) {
                var grid  = document.getElementById('prodGrid');
                var table = document.getElementById('tableWrap');
                var gBtn  = document.getElementById('gridViewBtn');
                var lBtn  = document.getElementById('listViewBtn');
                if (v === 'grid') {
                    grid.classList.remove('hidden'); table.classList.add('hidden');
                    gBtn.classList.add('active');    lBtn.classList.remove('active');
                } else {
                    grid.classList.add('hidden');    table.classList.remove('hidden');
                    lBtn.classList.add('active');    gBtn.classList.remove('active');
                }
            };

            /* ── Sort ── */
            function getSortFn(val) {
                switch (val) {
                    case 'id':         return function (a, b) { return +a.dataset.id    - +b.dataset.id; };
                    case 'date-asc':   return function (a, b) { return +a.dataset.date  - +b.dataset.date; };
                    case 'date-desc':  return function (a, b) { return +b.dataset.date  - +a.dataset.date; };
                    case 'total-asc':  return function (a, b) { return +a.dataset.total - +b.dataset.total; };
                    case 'total-desc': return function (a, b) { return +b.dataset.total - +a.dataset.total; };
                    default:           return function () { return 0; };
                }
            }

            /* ── Apply ── */
            function applyFilters() {
                var q      = (document.getElementById('searchInput').value || '').toLowerCase().trim();
                var sortFn = getSortFn(document.getElementById('sortSel').value);

                var grid  = document.getElementById('prodGrid');
                var cards = Array.from(grid.querySelectorAll('.prod-card'));
                var show  = cards.filter(function (el) { return !q || el.dataset.search.includes(q); });
                var hide  = cards.filter(function (el) { return  q && !el.dataset.search.includes(q); });
                show.sort(sortFn);
                show.forEach(function (el) { el.style.display = ''; grid.appendChild(el); });
                hide.forEach(function (el) { el.style.display = 'none'; });

                var tbody    = document.getElementById('tableBody');
                var rows     = Array.from(tbody.querySelectorAll('tr[data-search]'));
                var showRows = rows.filter(function (el) { return !q || el.dataset.search.includes(q); });
                var hideRows = rows.filter(function (el) { return  q && !el.dataset.search.includes(q); });
                showRows.sort(sortFn);
                showRows.forEach(function (el) { el.style.display = ''; tbody.appendChild(el); });
                hideRows.forEach(function (el) { el.style.display = 'none'; });

                var pi = document.getElementById('pageInfo');
                if (pi) {
                    pi.textContent = q
                        ? 'Showing ' + show.length + ' of ' + cards.length + ' matching'
                        : 'Showing 1\u2013' + Math.min(12, cards.length) + ' of ' + cards.length;
                }
            }

            document.getElementById('searchInput').addEventListener('input', applyFilters);
            document.getElementById('sortSel').addEventListener('change', applyFilters);

            /* ── Bulk ── */
            window.toggleSelectAll = function (cb) {
                document.querySelectorAll('.row-check').forEach(function (c) { c.checked = cb.checked; });
                updateBulkBar();
            };

            function updateBulkBar() {
                var count = document.querySelectorAll('.row-check:checked').length;
                document.getElementById('bulkCount').textContent = count;
                document.getElementById('bulkBar').style.display = count > 0 ? 'flex' : 'none';
            }

            window.clearSelection = function () {
                document.querySelectorAll('input[type=checkbox]').forEach(function (c) { c.checked = false; });
                updateBulkBar();
            };

            window.bulkDelete = function () {
                if (confirm('Delete selected orders?')) { showToast('Selected orders deleted'); clearSelection(); }
            };

            document.addEventListener('change', function (e) {
                if (e.target.classList.contains('row-check')) updateBulkBar();
            });

            /* ── Toast ── */
            window.showToast = function (msg) {
                var t = document.createElement('div');
                t.textContent = msg;
                t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:var(--accent);color:#fff;padding:10px 20px;border-radius:8px;z-index:9999;font-size:14px;box-shadow:0 4px 16px rgba(0,0,0,.2);';
                document.body.appendChild(t);
                setTimeout(function () { t.remove(); }, 2500);
            };

        })();
    </script>
}

