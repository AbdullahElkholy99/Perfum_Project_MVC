
@model PagedResult<OrderVM, OrderFilter, DashBoardOrder>

@{
    ViewData["Title"] = "Orders";
    Layout = "~/Views/Shared/_DashboardAdminLayOut.cshtml";
    var orders = Model?.Items ?? new List<OrderVM>();
    var totalCount = Model?.TotalCount ?? 0;
    var activeCount = orders.Count(o => o.Status == Status.Active);
    var inactiveCount = orders.Count(o => o.Status == Status.Inactive);
    var pendingCount = orders.Count(o => o.Status == Status.Pending);
    var expiredCount = orders.Count(o => o.Status == Status.Expired);
}

<link href="~/css/Dashbord/order.css" rel="stylesheet" />

<div class="order-page"  >

    @* ── Header ── *@
    <div class="topbar">
        <div>
            <div class="page-title">Orders <span>Management</span></div>
            <div class="page-subtitle">@totalCount order@(totalCount == 1 ? "" : "s")</div>
        </div>
        <div class="topbar-actions">

            <button class="btn btn-ghost" onclick="showToast('Orders exported')">
                <i class="fa-solid fa-file-arrow-down"></i>
                Export
            </button>

            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-cart-plus"></i>
                Add Order
            </a>

        </div>
    </div>

    @* ── Alerts ── *@
    @if (TempData["Success"] != null)
    {
        <div class="alert-success">✓ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-error">✕ @TempData["Error"]</div>
    }

    @* ── Stats ── *@
    <div class="stat-strip">
        <div class="mini-stat">
            <div class="mini-icon ic-amber">
                <i class="fa-solid fa-cart-shopping"></i>
            </div>
            <div>
                <div class="mini-val">@totalCount</div>
                <div class="mini-label">Total Orders</div>
            </div>
        </div>

        <div class="mini-stat">
            <div class="mini-icon ic-sage">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <div>
                <div class="mini-val">@activeCount</div>
                <div class="mini-label">Active</div>
            </div>
        </div>

        <div class="mini-stat">
            <div class="mini-icon ic-gold">
                <i class="fa-solid fa-hourglass-half"></i>
            </div>
            <div>
                <div class="mini-val">@pendingCount</div>
                <div class="mini-label">Pending</div>
            </div>
        </div>

        <div class="mini-stat">
            <div class="mini-icon ic-rose">
                <i class="fa-solid fa-circle-xmark"></i>
            </div>
            <div>
                <div class="mini-val">@inactiveCount</div>
                <div class="mini-label">Inactive</div>
            </div>
        </div>

        <div class="mini-stat">
            <div class="mini-icon ic-dark">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div>
                <div class="mini-val">@expiredCount</div>
                <div class="mini-label">Expired</div>
            </div>
        </div>
    </div>

    @* ── Toolbar ── *@
    <div class="toolbar">
        <div class="search-bar">
            <span style="color:var(--text3);font-size:16px">⌕</span>
            <input id="searchInput" placeholder="Search orders…" />
        </div>
        <select class="sort-select" id="sortSel"
                style="appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22><path fill=%22%23a08060%22 d=%22M0 0l5 6 5-6z%22/></svg>');background-repeat:no-repeat;background-position:right 12px center;padding-right:30px;">
            <option value="id">Order ID</option>
            <option value="date-desc">Date ↓ Newest</option>
            <option value="date-asc">Date ↑ Oldest</option>
            <option value="total-desc">Total ↓</option>
            <option value="total-asc">Total ↑</option>
        </select>
        <div class="view-toggle">
            <div class="view-btn active" id="gridViewBtn" onclick="switchView('grid')" title="Grid">⊞</div>
            <div class="view-btn" id="listViewBtn" onclick="switchView('list')" title="List">☰</div>
        </div>
    </div>

    @* ── Bulk bar ── *@
    <div class="bulk-bar" id="bulkBar" style="display:none">
        <div class="bulk-text">Selected: <strong id="bulkCount">0</strong></div>
        <button class="btn btn-ghost btn-sm" onclick="clearSelection()">Clear</button>
        <button class="btn btn-danger btn-sm" onclick="bulkDelete()">✕ Delete</button>
    </div>

    @* ════════════════════════════
       GRID VIEW
    ════════════════════════════ *@
    <div id="gridView">
        <div class="prod-grid" id="prodGrid">
            @foreach (var o in orders)
            {
                string statusClass = "sb-out";
                if (o.Status == Status.Active) { statusClass = "sb-in"; }
                if (o.Status == Status.Pending) { statusClass = "sb-low"; }

                string addrText = o.ShippingAddress != null ? (o.ShippingAddress) : "No address";

                string searchText = (o.Id.ToString() + " " + addrText + " " + o.Status.ToString()).ToLowerInvariant();
                string dateTicks = o.Date != null ? o.Date.Value.Ticks.ToString() : "0";

                <div class="prod-card"
                     data-id="@o.Id"
                     data-status="@o.Status.ToString()"
                     data-search="@searchText"
                     data-date="@dateTicks"
                     data-total="@o.TotalPrice">

                    <div class="stock-badge @statusClass">@o.Status</div>

                    <div class="prod-banner order-banner">
                        <span class="order-icon">🧾</span>
                    </div>

                    <div class="prod-body">
                        <div class="prod-category">Order · @(o.Date != null ? o.Date.Value.ToString("MMM dd, yyyy") : "—")</div>
                        <div class="prod-name">#@o.Id</div>
                        <div style="font-size:12px;color:var(--text3);margin-top:-2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @addrText
                        </div>
                        <div class="prod-footer">
                            <div class="prod-price">$@o.TotalPrice.ToString("N2")</div>
                            <div>
                                <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-ghost btn-sm">Details</a>
                                <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-ghost btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@o.Id" class="btn btn-danger btn-sm">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div id="gridEmpty" style="display:none;grid-column:1/-1;text-align:center;padding:60px;color:var(--text3)">
            No orders match your search.
        </div>
        <div class="pagination" id="gridPagination"></div>
    </div>

    @* ════════════════════════════
       TABLE VIEW
    ════════════════════════════ *@
    <div id="listView" style="display:none">
        <div class="table-wrap">
            <table class="prod-table">
                <thead>
                    <tr>
                        <th style="width:32px">
                            <input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)"
                                   style="accent-color:var(--accent);cursor:pointer;width:15px;height:15px;" />
                        </th>
                        <th>Order ID</th>
                        <th>Shipping Address</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    @foreach (var o in orders)
                    {
                        string statusClass = "sb-out";
                        if (o.Status == Status.Active) { statusClass = "sb-in"; }
                        if (o.Status == Status.Pending) { statusClass = "sb-low"; }

                        string addrText = o.ShippingAddress != null
                        ? (o.ShippingAddress)
                        : "—";
                        string searchText = (o.Id.ToString() + " " + addrText + " " + o.Status.ToString()).ToLowerInvariant();
                        string dateTicks = o.Date != null ? o.Date.Value.Ticks.ToString() : "0";

                        <tr class="order-row"
                            data-id="@o.Id"
                            data-status="@o.Status.ToString()"
                            data-search="@searchText"
                            data-date="@dateTicks"
                            data-total="@o.TotalPrice">
                            <td>
                                <input type="checkbox" class="row-check"
                                       style="accent-color:var(--accent);cursor:pointer;width:15px;height:15px;" />
                            </td>
                            <td>
                                <div class="prod-identity">
                                    <div class="prod-thumb" style="background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:18px;">🧾</div>
                                    <div>
                                        <div class="pid-name">Order #@o.Id</div>
                                        <div class="pid-sku">@(o.Date != null ? o.Date.Value.ToString("MMM dd, yyyy HH:mm") : "—")</div>
                                    </div>
                                </div>
                            </td>
                            <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@addrText</td>
                            <td>@(o.Date != null ? o.Date.Value.ToString("yyyy-MM-dd") : "—")</td>
                            <td><span class="price-val">$@o.TotalPrice.ToString("N2")</span></td>
                            <td><span class="stock-badge @statusClass" style="position:static;font-size:11px;">@o.Status</span></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-ghost btn-sm">Details</a>
                                <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-ghost btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@o.Id" class="btn btn-danger btn-sm">✕</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div id="tableEmpty" style="display:none;text-align:center;padding:48px;color:var(--text3)">
                No orders match your search.
            </div>
        </div>
        <div class="pagination" id="listPagination"></div>
    </div>

</div>

@section Scripts {
    <script>
        var PAGE_SIZE   = 10;
        var allCards    = [];
        var allRows     = [];
        var filteredC   = [];
        var filteredR   = [];
        var gridPage    = 1;
        var listPage    = 1;

        window.addEventListener('DOMContentLoaded', function () {
            allCards  = Array.from(document.querySelectorAll('#prodGrid .prod-card'));
            allRows   = Array.from(document.querySelectorAll('#tableBody .order-row'));
            filteredC = allCards.slice();
            filteredR = allRows.slice();
            renderGrid();
            renderList();
        });

        /* ── View toggle ── */
        window.switchView = function (v) {
            document.getElementById('gridView').style.display = v === 'grid' ? '' : 'none';
            document.getElementById('listView').style.display = v === 'list' ? '' : 'none';
            document.getElementById('gridViewBtn').classList.toggle('active', v === 'grid');
            document.getElementById('listViewBtn').classList.toggle('active', v === 'list');
        };

        /* ── Filter + Sort ── */
        window.applyFilters = function () {
            var q      = (document.getElementById('searchInput').value || '').toLowerCase().trim();
            var status = document.getElementById('statusSel').value;
            var sort   = document.getElementById('sortSel').value;

            function matches(el) {
                if (q && (el.dataset.search || '').indexOf(q) === -1) return false;
                if (status !== 'all' && el.dataset.status !== status)  return false;
                return true;
            }

            function sortFn(a, b) {
                switch (sort) {
                    case 'id':         return parseInt(a.dataset.id)      - parseInt(b.dataset.id);
                    case 'date-asc':   return parseInt(a.dataset.date)    - parseInt(b.dataset.date);
                    case 'date-desc':  return parseInt(b.dataset.date)    - parseInt(a.dataset.date);
                    case 'total-asc':  return parseFloat(a.dataset.total) - parseFloat(b.dataset.total);
                    case 'total-desc': return parseFloat(b.dataset.total) - parseFloat(a.dataset.total);
                    default:           return 0;
                }
            }

            filteredC = allCards.filter(matches).sort(sortFn);
            filteredR = allRows.filter(matches).sort(sortFn);
            gridPage  = 1;
            listPage  = 1;
            renderGrid();
            renderList();
        };

        /* ── Render Grid ── */
        function renderGrid() {
            var body  = document.getElementById('prodGrid');
            var empty = document.getElementById('gridEmpty');
            allCards.forEach(function (c) { c.style.display = 'none'; });
            if (filteredC.length === 0) {
                empty.style.display = '';
                document.getElementById('gridPagination').innerHTML = '';
                return;
            }
            empty.style.display = 'none';
            var start = (gridPage - 1) * PAGE_SIZE;
            filteredC.forEach(function (c, i) {
                body.appendChild(c);
                c.style.display = (i >= start && i < start + PAGE_SIZE) ? '' : 'none';
            });
            renderPagination('gridPagination', filteredC.length, gridPage, 'grid');
        }

        /* ── Render List ── */
        function renderList() {
            var body  = document.getElementById('tableBody');
            var empty = document.getElementById('tableEmpty');
            allRows.forEach(function (r) { r.style.display = 'none'; });
            if (filteredR.length === 0) {
                empty.style.display = '';
                document.getElementById('listPagination').innerHTML = '';
                return;
            }
            empty.style.display = 'none';
            var start = (listPage - 1) * PAGE_SIZE;
            filteredR.forEach(function (r, i) {
                body.appendChild(r);
                r.style.display = (i >= start && i < start + PAGE_SIZE) ? '' : 'none';
            });
            renderPagination('listPagination', filteredR.length, listPage, 'list');
        }

        /* ── Pagination renderer ── */
        function renderPagination(containerId, total, page, view) {
            var tp = Math.ceil(total / PAGE_SIZE);
            var el = document.getElementById(containerId);
            if (tp <= 1) { el.innerHTML = ''; return; }
            var from = Math.min((page - 1) * PAGE_SIZE + 1, total);
            var to   = Math.min(page * PAGE_SIZE, total);
            var html = '<div class="pag-info">Showing ' + from + '&ndash;' + to + ' of ' + total + '</div>';
            html += '<div class="pag-btns">';
            html += '<button class="pag-btn" ' + (page === 1 ? 'disabled' : '') + ' onclick="pagGo(\'' + view + '\',' + (page - 1) + ')">&#8249;</button>';
            for (var i = 1; i <= tp; i++) {
                if (i === 1 || i === tp || Math.abs(i - page) <= 1) {
                    html += '<button class="pag-btn ' + (i === page ? 'pag-active' : '') + '" onclick="pagGo(\'' + view + '\',' + i + ')">' + i + '</button>';
                } else if (Math.abs(i - page) === 2) {
                    html += '<span class="pag-ellipsis">&hellip;</span>';
                }
            }
            html += '<button class="pag-btn" ' + (page === tp ? 'disabled' : '') + ' onclick="pagGo(\'' + view + '\',' + (page + 1) + ')">&#8250;</button>';
            html += '</div>';
            el.innerHTML = html;
        }

        window.pagGo = function (view, p) {
            if (view === 'grid') { gridPage = p; renderGrid(); }
            else                 { listPage = p; renderList(); }
            document.querySelector('.order-page').scrollIntoView({ behavior: 'smooth', block: 'start' });
        };

        /* ── Bulk select ── */
        window.toggleSelectAll = function (cb) {
            document.querySelectorAll('.row-check').forEach(function (c) { c.checked = cb.checked; });
            updateBulkBar();
        };

        function updateBulkBar() {
            var count = document.querySelectorAll('.row-check:checked').length;
            document.getElementById('bulkCount').textContent = count;
            document.getElementById('bulkBar').style.display = count > 0 ? 'flex' : 'none';
        }

        window.clearSelection = function () {
            document.querySelectorAll('input[type=checkbox]').forEach(function (c) { c.checked = false; });
            updateBulkBar();
        };

        window.bulkDelete = function () {
            if (confirm('Delete selected orders?')) { showToast('Done'); clearSelection(); }
        };

        document.addEventListener('change', function (e) {
            if (e.target.classList.contains('row-check')) updateBulkBar();
        });

        /* ── CSV Export ── */
        window.exportCSV = function () {
            var rows = [['ID', 'Address', 'Date', 'Total', 'Status']];
            filteredR.forEach(function (r) {
                var tds = r.querySelectorAll('td');
                rows.push([r.dataset.id, tds[2] ? tds[2].innerText : '', tds[3] ? tds[3].innerText : '', r.dataset.total, r.dataset.status]);
            });
            var csv  = rows.map(function (r) { return r.map(function (v) { return '"' + String(v || '').replace(/"/g, '""') + '"'; }).join(','); }).join('\n');
            var blob = new Blob([csv], { type: 'text/csv' });
            var a    = document.createElement('a');
            a.href = URL.createObjectURL(blob); a.download = 'orders.csv'; a.click();
        };

        /* ── Toast ── */
        window.showToast = function (msg) {
            var t = document.getElementById('toast');
            if (t) { document.getElementById('toastMsg').textContent = msg; t.classList.add('show'); setTimeout(function () { t.classList.remove('show'); }, 2500); }
        };
    </script>
}
