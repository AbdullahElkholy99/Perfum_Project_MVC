@model EditOrderVM
@{
    ViewData["Title"] = "Edit Order";
    Layout = "~/Views/Shared/_DashboardAdminLayOut.cshtml";
    var orderId = ViewBag.OrderId as int? ?? 0;
}

<link href="~/css/Dashbord/order.css" rel="stylesheet" />
 
<div class="order-page">

    <!-- Header -->
    <div class="topbar">
        <div>
            <div class="page-title">
                <i class="fa-solid fa-pen-to-square"></i>
                Edit <span>Order #@orderId</span>
            </div>

            <div class="page-subtitle">Update order information</div>
        </div>

        <div class="topbar-actions">

            <a asp-action="Details" asp-route-id="@orderId" class="btn btn-ghost">
                <i class="fa-solid fa-eye"></i> Details
            </a>

            <a asp-action="Index" class="btn btn-ghost">
                <i class="fa-solid fa-arrow-left"></i> Back
            </a>

        </div>
    </div>

    <!-- Form Card -->
    <div class="form-card">

        <div class="detail-card-header" style="margin-bottom:24px;">
            <span class="detail-card-title">
                <i class="fa-solid fa-pen"></i> Edit Order Details
            </span>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error" style="margin-bottom:18px;">
                <i class="fa-solid fa-circle-exclamation"></i>
                Please fix the errors below before submitting.
            </div>
        }

        <form asp-action="Edit" asp-route-id="@orderId" method="post">
            @Html.AntiForgeryToken()

            <div class="form-grid">

                <!-- Address -->
                <div class="form-group">
                    <label asp-for="ShippingAddress" class="form-label">
                        <i class="fa-solid fa-location-dot"></i> Shipping Address
                    </label>

                    <textarea asp-for="ShippingAddress"
                              class="form-control form-textarea"
                              placeholder="Enter full shipping address…"
                              rows="3"></textarea>

                    <span asp-validation-for="ShippingAddress" class="field-error"></span>
                </div>

                <!-- Date -->
                <div class="form-group">
                    <label asp-for="Date" class="form-label">
                        <i class="fa-solid fa-calendar"></i> Order Date
                    </label>

                    <input asp-for="Date"
                           type="datetime-local"
                           class="form-control" />

                    <span asp-validation-for="Date" class="field-error"></span>
                </div>

                <!-- Status -->
                <div class="form-group">
                    <label asp-for="Status" class="form-label">
                        <i class="fa-solid fa-tag"></i> Status
                    </label>

                    <select asp-for="Status"
                            class="form-control sort-select"
                            asp-items="Html.GetEnumSelectList<Status>()"></select>

                    <span asp-validation-for="Status" class="field-error"></span>
                </div>

                <!-- Total -->
                <div class="form-group">
                    <label asp-for="TotalPrice" class="form-label">
                        <i class="fa-solid fa-dollar-sign"></i> Total Price
                    </label>

                    <input asp-for="TotalPrice"
                           type="number"
                           step="0.01"
                           min="0"
                           class="form-control"
                           placeholder="0.00"
                           readonly
                           style="cursor:not-allowed;opacity:.7;" />

                    <span style="font-size:11px;color:var(--text3);">
                        Auto-calculated from order items
                    </span>

                    <span asp-validation-for="TotalPrice" class="field-error"></span>
                </div>

            </div>

            <div class="form-actions">

                <a asp-action="Details" asp-route-id="@orderId" class="btn btn-ghost">
                    <i class="fa-solid fa-xmark"></i> Cancel
                </a>

                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Save Changes
                </button>

            </div>

        </form>
    </div>

</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
