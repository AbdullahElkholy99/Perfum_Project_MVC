@model EditOrderItemVM
@{
    ViewData["Title"] = "Edit Order Item";
    Layout = "~/Views/Shared/_DashboardOrdersAdminLayOut.cshtml";
    var itemId = ViewBag.ItemId as int? ?? 0;
}

<link href="~/css/dashbord/order.css" rel="stylesheet" />

<div class="order-page">

    @* ── Header ── *@
    <div class="topbar">
        <div>
            <div class="page-title">Edit <span>Item #@itemId</span></div>
            <div class="page-subtitle">Modify item in Order #@Model.OrderId</div>
        </div>
        <div class="topbar-actions">
            <a asp-action="OrderItems" asp-route-id="@Model.OrderId" class="btn btn-ghost">← Back to Items</a>
        </div>
    </div>

    @* ── Form Card ── *@
    <div class="form-card" style="max-width:520px;">
        <div class="detail-card-header" style="margin-bottom:24px;">
            <span class="detail-card-title">✎ Edit Item Details</span>
        </div>

        <form asp-action="EditItem" asp-route-id="@itemId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="OrderId" />
            <input type="hidden" asp-for="ProductId" />

            <div class="form-grid" style="grid-template-columns:1fr;">

                <div class="form-group">
                    <label class="form-label">🔖 Product ID</label>
                    <div class="form-control" style="background:var(--surface2);color:var(--text3);cursor:not-allowed;">
                        @Model.ProductId
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Quantity" class="form-label">🔢 Quantity</label>
                    <input asp-for="Quantity" type="number" min="1" class="form-control" />
                    <span asp-validation-for="Quantity" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="UnitPrice" class="form-label">💰 Unit Price</label>
                    <input asp-for="UnitPrice" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="UnitPrice" class="field-error"></span>
                </div>

            </div>

            <div class="form-actions">
                <a asp-action="OrderItems" asp-route-id="@Model.OrderId" class="btn btn-ghost">Cancel</a>
                <button type="submit" class="btn btn-primary">💾 Save Changes</button>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
