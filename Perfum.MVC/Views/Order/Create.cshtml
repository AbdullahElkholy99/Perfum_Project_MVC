@model AddOrderVM

@{
    ViewData["Title"] = "Create Order";
    Layout = "~/Views/Shared/_DashboardAdminLayOut.cshtml";
}

<link href="~/css/dashbord/order.css" rel="stylesheet" />

<div class="order-page">

    @* ── Header ── *@
    <div class="topbar">
        <div>
            <div class="page-title">Create <span>Order</span></div>
            <div class="page-subtitle">Add a new order to the system</div>
        </div>
        <div class="topbar-actions">
            <a asp-action="Index" class="btn btn-ghost">← Back to Orders</a>
        </div>
    </div>

    @* ── Form Card ── *@
    <div class="form-card">
        <div class="detail-card-header" style="margin-bottom:24px;">
            <span class="detail-card-title">🛒 Order Details</span>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error" style="margin-bottom:18px;">
                Please fix the errors below before submitting.
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="ShippingAddress" class="form-label">📍 Shipping Address</label>
                    <textarea asp-for="ShippingAddress" class="form-control form-textarea"
                              placeholder="Enter full shipping address…" rows="3"></textarea>
                    <span asp-validation-for="ShippingAddress" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Date" class="form-label">📅 Order Date</label>
                    <input asp-for="Date" type="datetime-local" class="form-control"
                           value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="Date" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Status" class="form-label">🔖 Status</label>
                    <select asp-for="Status" class="form-control sort-select"
                            asp-items="Html.GetEnumSelectList<Status>()"></select>
                    <span asp-validation-for="Status" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="TotalPrice" class="form-label">💰 Total Price</label>
                    <input asp-for="TotalPrice" type="number" step="0.01" min="0" class="form-control"
                           placeholder="0.00" readonly style="cursor:not-allowed;opacity:.7;" />
                    <span style="font-size:11px;color:var(--text3);">Auto-calculated from order items</span>
                    <span asp-validation-for="TotalPrice" class="field-error"></span>
                </div>

            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn btn-ghost">Cancel</a>
                <button type="submit" class="btn btn-primary">✦ Create Order</button>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
