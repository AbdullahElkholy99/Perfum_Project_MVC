@model CustomerVM

@{
    ViewData["Title"] = "Customer Details";
    Layout = "~/Views/Shared/_DashboardAdminLayOut.cshtml";
    var ordersCount  = Model?.Orders?.Count  ?? 0;
    var reviewsCount = Model?.Reviews?.Count ?? 0;
    var totalSpent   = Model?.Orders?.Sum(o => o.TotalPrice) ?? 0;
}

<link href="~/css/Dashbord/order.css" rel="stylesheet" />
<link href="~/css/Dashbord/customer.css" rel="stylesheet" />

<div class="order-page">

    <!-- Header -->
    <div class="topbar">
        <div>
            <div class="page-title">
                <i class="fa-solid fa-user"></i>
                Customer <span>Details</span>
            </div>

            <div class="page-subtitle">
                <a asp-action="Index" style="color:var(--accent)">
                    <i class="fa-solid fa-users"></i> Customers
                </a>
                / @Model?.UserName
            </div>
        </div>

        <div class="topbar-actions">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-ghost">
                <i class="fa-solid fa-pen"></i> Edit
            </a>

            <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger">
                <i class="fa-solid fa-trash"></i> Delete
            </a>
        </div>
    </div>

    <div class="detail-grid">

        <!-- Profile Card -->
        <div class="detail-card detail-card-profile">

            <div class="profile-avatar-wrap">
                @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                {
                    <img src="/@Model.ImageUrl" alt="@Model.UserName" class="profile-avatar" />
                }
                else
                {
                    <div class="profile-avatar profile-avatar-ph">
                        @(Model?.UserName?.Substring(0, 1).ToUpper() ?? "?")
                    </div>
                }
            </div>

            <div class="profile-name">@Model?.UserName</div>
            <div class="profile-email">@Model?.Email</div>

            <div class="profile-stats">

                <div class="pstat">
                    <div class="pstat-val">@ordersCount</div>
                    <div class="pstat-label">
                        <i class="fa-solid fa-cart-shopping"></i> Orders
                    </div>
                </div>

                <div class="pstat">
                    <div class="pstat-val">@reviewsCount</div>
                    <div class="pstat-label">
                        <i class="fa-solid fa-star"></i> Reviews
                    </div>
                </div>

                <div class="pstat">
                    <div class="pstat-val">$@totalSpent.ToString("N0")</div>
                    <div class="pstat-label">
                        <i class="fa-solid fa-dollar-sign"></i> Spent
                    </div>
                </div>

            </div>

            <div class="profile-info">

                <div class="info-row">
                    <span class="info-label">
                        <i class="fa-solid fa-phone"></i> Phone
                    </span>
                    <span class="info-val">@(Model?.PhoneNumber ?? "—")</span>
                </div>

                <div class="info-row">
                    <span class="info-label">
                        <i class="fa-solid fa-location-dot"></i> Address
                    </span>
                    <span class="info-val">@(Model?.Address ?? "—")</span>
                </div>

                <div class="info-row">
                    <span class="info-label">
                        <i class="fa-solid fa-id-card"></i> ID
                    </span>
                    <span class="info-val">#@Model?.Id</span>
                </div>

            </div>

        </div>

        <!-- Right Column -->
        <div class="detail-right">

            <!-- Orders -->
            <div class="detail-card">

                <div class="detail-card-title">
                    <i class="fa-solid fa-cart-shopping"></i>
                    Orders
                    <span class="badge-count">@ordersCount</span>
                </div>

                @if (Model?.Orders != null && Model.Orders.Any())
                {
                    <table class="order-table" style="margin-top:10px">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Total</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var o in Model.Orders)
                            {
                                <tr>
                                    <td>
                                        <span class="order-id">
                                            <i class="fa-solid fa-hashtag"></i> @o.Id
                                        </span>
                                    </td>

                                    <td>
                                        <i class="fa-solid fa-calendar"></i>
                                        @(o.Date?.ToString("MMM dd, yyyy") ?? "—")
                                    </td>

                                    <td>
                                        <span class="status-badge status-@o.Status.ToString().ToLower()">
                                            @o.Status
                                        </span>
                                    </td>

                                    <td>
                                        <strong>
                                            <i class="fa-solid fa-dollar-sign"></i>
                                            @o.TotalPrice.ToString("N2")
                                        </strong>
                                    </td>
                                </tr>
                            }
                        </tbody>

                        <tfoot>
                            <tr>
                                <td colspan="3" style="text-align:right;font-weight:600;color:var(--text2)">
                                    Total Spent
                                </td>

                                <td>
                                    <strong style="color:var(--accent)">
                                        $@totalSpent.ToString("N2")
                                    </strong>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <div class="empty-inline">
                        <i class="fa-solid fa-box-open"></i> No orders placed yet
                    </div>
                }
            </div>

            <!-- Reviews -->
            <div class="detail-card">

                <div class="detail-card-title">
                    <i class="fa-solid fa-star"></i>
                    Reviews
                    <span class="badge-count">@reviewsCount</span>
                </div>

                @if (Model?.Reviews != null && Model.Reviews.Any())
                {
                    <div class="reviews-list">

                        @foreach (var r in Model.Reviews)
                        {
                            <div class="review-item">

                                <div class="review-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fa-solid fa-star"
                                           style="color:@(i <= r.Rating ? "#c98a10" : "var(--border)")"></i>
                                    }
                                </div>

                                <div class="review-comment">@r.Comment</div>

                                <div class="review-date">
                                    <i class="fa-solid fa-calendar"></i>
                                    @r.ReviewDate.ToString("MMM dd, yyyy")
                                </div>

                            </div>
                        }

                    </div>
                }
                else
                {
                    <div class="empty-inline">
                        <i class="fa-solid fa-comment-slash"></i>
                        No reviews submitted yet
                    </div>
                }

            </div>

        </div>
    </div>

</div>