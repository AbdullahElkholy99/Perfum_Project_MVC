<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sillage — Categories</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link href="~/css/dashbord/dashboard.css" rel="stylesheet" />
</head>
<body>
    <div class="layout">

        <!-- ── Sidebar ── -->
        <aside class="sidebar">
            <div class="logo">
                <div class="logo-text">Sillage</div>
                <div class="logo-sub">Fragrance Studio</div>
            </div>
            
            <div class="nav-section">
                <div class="nav-label">Overview</div>
                <div class="nav-item"><span class="nav-icon">◈</span> Dashboard</div>
                <div class="nav-item"><span class="nav-icon">◇</span> Analytics</div>

            </div>
            <div class="nav-section" style="margin-top:12px">
                <div class="nav-label">Catalogue</div>
                <div class="nav-item active">
                    <a asp-controller="Product" asp-action="Index">
                        <span class="nav-icon">✦</span>
                        Products
                    </a>
                </div>
                <div class="nav-item">
                    <a asp-controller="Category" asp-action="Index"><span class="nav-icon">⬡</span>  Categories</a>
                 
                </div>
                <div class="nav-item"><span class="nav-icon">◎</span> Ingredients</div>
            </div>
            <div class="nav-section" style="margin-top:12px">
                <div class="nav-label">Commerce</div>
                <div class="nav-item"><span class="nav-icon">▣</span> Orders</div>
                <div class="nav-item"><span class="nav-icon">◯</span> Customers</div>
                <div class="nav-item"><span class="nav-icon">▷</span> Marketing</div>
            </div>
            <div class="sidebar-bottom">
                <div class="theme-toggle" onclick="toggleTheme()">
                    <span id="themeLabel">Dark Mode</span>
                    <div class="toggle-pill" id="pill"><div class="toggle-dot"></div></div>
                </div>
            </div>
        </aside>

        <!-- ── Main ── -->
        <main class="main">

          
            <div class="DashboardContent">
                @RenderBody();
            </div>

        </main>
    </div>

 
    

    <!-- ── Toast ── -->
    <div class="toast" id="toast">
        <div class="toast-dot"></div>
        <span id="toastMsg">Saved successfully</span>
    </div>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/dashboard/dashboard.js"></script>
    @await RenderSectionAsync("Scripts",required:false)
</body>
</html>
