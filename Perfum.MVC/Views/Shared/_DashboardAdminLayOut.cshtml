
@{
    var adminId  = @User.Identity?.IsAuthenticated.ToString().ToLower();
    var adminName = @User.Identity?.Name;
}

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perfum — Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Sillage</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet" />
    <link href="~/css/dashbord/dashboard.css" rel="stylesheet" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        /* DARK MODE — override dashboard.css vars */
        [data-theme="dark"] {
            --bg: #0f0c09 !important;
            --bg2: #1a1410 !important;
            --bg3: #231b13 !important;
            --surface: #1e1710 !important;
            --surface2: #261e15 !important;
            --border: rgba(200,150,80,0.14) !important;
            --text: #f0e8da !important;
            --text2: #c8aa80 !important;
            --text3: #8a6845 !important;
            --accent: #e09a5a !important;
            --accent2: #c8854a !important;
            --gold: #e8c060 !important;
            --rose: #d99090 !important;
            --green: #90b894 !important;
            --blue: #90a8d8 !important;
            --shadow: rgba(0,0,0,0.4) !important;
            --shadow2: rgba(0,0,0,0.6) !important;
            --glow: rgba(224,154,90,0.1) !important;
            --glow2: rgba(224,154,90,0.05) !important;
        }

            /* Dark: colour elements that use hardcoded colours in dashboard.css */
            [data-theme="dark"] body {
                background: var(--bg);
                color: var(--text);
            }

            [data-theme="dark"] .sidebar {
                background: #1a1410;
                border-color: rgba(200,150,80,0.14);
            }

            [data-theme="dark"] .nav-bar {
                background: #1a1410;
                border-color: rgba(200,150,80,0.14);
            }

            [data-theme="dark"] .page-title {
                color: var(--text);
            }

            [data-theme="dark"] .user-name {
                color: var(--text2);
            }

            [data-theme="dark"] .navbar-icon:hover {
                background: var(--bg2);
            }

            [data-theme="dark"] .navbar-user:hover {
                background: var(--bg2);
            }

            [data-theme="dark"] .search-box input {
                background: var(--bg2);
                border-color: var(--border);
                color: var(--text);
            }

            [data-theme="dark"] .nav-item a {
                color: var(--text2);
            }

            [data-theme="dark"] .nav-item:hover {
                background: var(--bg2);
            }

            [data-theme="dark"] .nav-item.active {
                background: var(--glow);
            }

                [data-theme="dark"] .nav-item.active a {
                    color: var(--accent);
                }

        /* ── Smooth transitions ── */
        body, .sidebar, .nav-bar, .nav-item, .search-box input,
        .mainDashboard, .surface, .btn, .mini-stat {
            transition: background .3s, color .3s, border-color .3s;
        }

        /* ── Theme toggle pill state ── */
        [data-theme="dark"] .toggle-pill {
            background: var(--accent) !important;
        }

        [data-theme="dark"] .toggle-dot {
            transform: translateX(16px);
        }

        /* ── Fix: pages with .order-page already have their own topbar,
                      no extra top spacing needed ── */
        .mainDashboard .order-page .topbar,
        .mainDashboard .order-page {
            margin-top: 0;
        }

        /* ── Auth dropdown in dashboard navbar ── */
        .navbar-right .auth-nav-dropdown { display: flex; align-items: center; }
        .navbar-right .auth-dropdown { position: relative; }
        .navbar-right .auth-trigger {
            display: flex; align-items: center; gap: 8px; padding: 4px 8px;
            border-radius: 8px; cursor: pointer; transition: 0.2s;
            border: none; background: none; font-size: 13px; color: #333;
            font-family: 'Jost', sans-serif;
        }
        .navbar-right .auth-trigger:hover { background: #f6f6f6; }
        [data-theme="dark"] .navbar-right .auth-trigger { color: var(--text2); }
        [data-theme="dark"] .navbar-right .auth-trigger:hover { background: var(--bg2); }
        .navbar-right .auth-avatar { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; }
        .navbar-right .auth-initial {
            width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
            background: var(--accent); color: #fff; font-size: 14px; font-weight: 500;
        }
        .navbar-right .auth-menu {
            position: absolute; right: 0; top: 100%; margin-top: 4px; min-width: 160px;
            background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
            box-shadow: var(--shadow2); padding: 6px 0; z-index: 100;
        }
        .navbar-right .auth-menu-item {
            display: block; width: 100%; padding: 10px 16px; text-align: left;
            border: none; background: none; cursor: pointer; font-size: 13px; color: var(--text);
            text-decoration: none; transition: 0.2s;
        }
        .navbar-right .auth-menu-item:hover { background: var(--bg2); }
        .navbar-right .auth-links { display: flex; gap: 12px; align-items: center; }
        .navbar-right .auth-link { font-size: 13px; color: var(--text3); text-decoration: none; }
        .navbar-right .auth-link:hover { color: var(--accent); }
    </style>
</head>
<body>

      @* ── Navbar ──  *@
    <header class="nav-bar">

        <div class="navbar-left">
            <div class="menu-btn" onclick="toggleSidebar()" style="margin:0 20px">
                <i class="fa-solid fa-bars"></i>
                </div>
            <h2 class="page-title">Dashboard</h2>
        </div>

        <div class="navbar-right">

            <div class="search-box">
                <input type="text" placeholder="Search...">
            </div>

            <div class="navbar-icon">
                <i class="fa-regular fa-bell"></i>
            </div>

            <!-- User Settings -->
            <div class="nav-user">
                <div class="nav-icon-btn" onclick="toggleUserMenu()" title="Account">
                    <i class="fa-solid fa-user-gear"></i>
                    @* <span >@adminName</span> *@
                </div>

                <div class="user-menu" id="userMenu">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Profile"><i class="fa-solid fa-address-card"></i> &nbsp;&nbsp;Profile</a>
                        <hr>
                        <a asp-controller="Account" asp-action="Logout"><i class="fa-solid fa-arrow-right-from-bracket"></i>&nbsp;&nbsp; Logout</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"><i class="fa-solid fa-arrow-right-to-bracket"></i> &nbsp;&nbsp;Login</a>
                        <a asp-asp-controller="Account" asp-action="Register">
                            <i class="fa-solid fa-person-circle-plus"></i>&nbsp;&nbsp;    Register
                        </a>
                    }
                </div>
            </div>
        </div>
    </header>

    <!-- ── Sidebar ── -->
    <aside class="sidebar">

        <div class="logo">
            <div class="logo-text">Sillage</div>
            <div class="logo-sub">Fragrance Studio</div>
        </div>

        @{
            var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        }

        <div class="nav-section">
            <div class="nav-label">Overview</div>

            <div class="nav-item @(ctrl == "Dashboard" ? "active" : "")">
                <a asp-controller="Dashboard" asp-action="Index">
                    <i class="fa-solid fa-chart-bar"></i> &nbsp;&nbsp;  Dashboard
                </a>
            </div>
        </div>

        <div class="nav-section" style="margin-top:14px">
            <div class="nav-label">Catalogue</div>
            <div class="nav-item @(ctrl == "Product" ? "active" : "")">
                <a asp-controller="Product" asp-action="Index">
                    <i class="fa-brands fa-product-hunt"></i>&nbsp;&nbsp; Products
                </a>
            </div>
       
            <div class="nav-item @(ctrl == "Category" ? "active" : "")">
                <a asp-controller="Category" asp-action="Index">
                    <i class="fa-solid fa-layer-group"></i>&nbsp;&nbsp; Categories
                </a>
            </div> 
        </div>

        <div class="nav-section" style="margin-top:14px">
            <div class="nav-label">Commerce</div>
            <div class="nav-item @(ctrl == "Order" ? "active" : "")">
                <a asp-controller="Order" asp-action="Index">
                    <i class="fa-brands fa-first-order"></i> &nbsp;&nbsp;Orders
                </a>
            </div>
            <div class="nav-item @(ctrl == "CustomerDashBoard" ? "active" : "")">
                <a asp-controller="CustomerDashBoard" asp-action="Index">
                    <i class="fa-solid fa-people-carry-box"></i> &nbsp;&nbsp;  Customers
                </a>
            </div>
         
        </div>

        <div class="sidebar-bottom">
            <div class="theme-toggle" onclick="toggleTheme()">
                <span id="themeLabel">Dark Mode</span>
                <div class="toggle-pill" id="pill">
                    <div class="toggle-dot"></div>
                </div>
            </div>
            <a asp-controller="Account"
               asp-action="Logout"
               class="logout-btn">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                Logout
            </a>
        </div>

    </aside>

    @* ── Main ── *@
    <main class="mainDashboard">
        @RenderBody()
    </main>

    @* ── Toast ── *@
    <div class="toast" id="toast">
        <div class="toast-dot"></div>
        <span id="toastMsg">Saved successfully</span>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/js/dashboard/dashboard.js"></script>

    <script>

        var isAuth  = @User.Identity.IsAuthenticated.ToString().ToLower();
        var adminName = "@User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value";

        /* ── Theme ── */
        function toggleTheme() {
            var html  = document.documentElement;
            var isDark = html.getAttribute('data-theme') === 'dark';
            html.setAttribute('data-theme', isDark ? 'light' : 'dark');
            document.getElementById('themeLabel').textContent = isDark ? 'Dark Mode' : 'Light Mode';
            localStorage.setItem('theme', isDark ? 'light' : 'dark');
        }

        /* Restore on load */
        (function () {
            if (localStorage.getItem('theme') === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                var l = document.getElementById('themeLabel');
                if (l) l.textContent = 'Light Mode';
            }
        })();

        /* ── Toast ── */
        function showToast(msg) {
            var t = document.getElementById('toast');
            document.getElementById('toastMsg').textContent = msg || 'Done';
            t.classList.add('show');
            setTimeout(function () { t.classList.remove('show'); }, 2500);
        }
    </script>
 
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
