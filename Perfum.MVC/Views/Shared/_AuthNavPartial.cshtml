@{
    var id = Context.Request.Cookies["Id"];
    var name = Context.Request.Cookies["Name"];
    var imagePath = Context.Request.Cookies["ImagePath"];
    var isLoggedIn = !string.IsNullOrEmpty(id) && !string.IsNullOrEmpty(name);
}
@if (isLoggedIn)
{
    <div class="auth-nav-dropdown">
        <details class="auth-dropdown">
            <summary class="auth-trigger">
                @if (!string.IsNullOrEmpty(imagePath))
                {
                    <img src="@imagePath" alt="" class="auth-avatar" />
                }
                else
                {
                    <span class="auth-initial">@(name?.Length > 0 ? name[0].ToString().ToUpperInvariant() : "?")</span>
                }
                <span class="auth-name">@name</span>
            </summary>
            <div class="auth-menu">
                <a asp-controller="Account" asp-action="Profile" class="auth-menu-item">My Profile</a>
                <a asp-controller="Account" asp-action="Logout" class="auth-menu-item">Logout</a>
            </div>
        </details>
    </div>
}
else
{
    <div class="auth-links">
        <a asp-controller="Account" asp-action="Login" class="auth-link">Login</a>
        <a asp-controller="Account" asp-action="Register" class="auth-link">Register</a>
    </div>
}
