@model Perfum.MVC.ViewModels.ProductCreatePageVM
@using Perfum.Services.ViewModels.ProductVM
@{
    ViewData["Title"] = "Add Product";
    Layout = "~/Views/Shared/_DashboardAdminLayOut.cshtml";
}
<link href="~/css/dashbord/product.css" rel="stylesheet" />
<div class="product-page">
    <div class="topbar">
        <div>
            <div class="page-title">Add <span>Product</span></div>
            <div class="page-subtitle">New fragrance</div>
        </div>
        <div class="topbar-actions">
            <a asp-action="Index" class="btn btn-ghost">Cancel</a>
        </div>
    </div>
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label" asp-for="MyAddProductVm.Name">Product Name</label>
            <input asp-for="MyAddProductVm.Name" class="form-input" placeholder="e.g. Rose Elixir" />
            <span asp-validation-for="MyAddProductVm.Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="MyAddProductVm.Descreption">Description</label>
            <textarea asp-for="MyAddProductVm.Descreption" class="form-input" rows="3" placeholder="Short description…"></textarea>
            <span asp-validation-for="MyAddProductVm.Descreption" class="text-danger"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="MyAddProductVm.Price">Price</label>
                <input asp-for="MyAddProductVm.Price" class="form-input" type="number" step="0.01" placeholder="185" />
                <span asp-validation-for="MyAddProductVm.Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="MyAddProductVm.Size_Ml">Size (ml)</label>
                <input asp-for="MyAddProductVm.Size_Ml" class="form-input" type="number" step="0.01" placeholder="100" />
                <span asp-validation-for="MyAddProductVm.Size_Ml" class="text-danger"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="MyAddProductVm.Stock">Stock</label>
                <input asp-for="MyAddProductVm.Stock" class="form-input" type="number" placeholder="24" />
                <span asp-validation-for="MyAddProductVm.Stock" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="MyAddProductVm.CategoryId">Category</label>
                @* <div style="margin:10px 0;color:var(--text3);">Categories loaded: @Model.Categories.Count</div> *@
                <select asp-for="MyAddProductVm.CategoryId" class="form-input" asp-items="Model.CategoryOptions">
                    <option value="">-- Select --</option>
                </select>
                <span asp-validation-for="MyAddProductVm.CategoryId" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="MyAddProductVm.Concentration">Concentration</label>
            <input asp-for="MyAddProductVm.Concentration" class="form-input" placeholder="e.g. Eau de Parfum" />
            <span asp-validation-for="MyAddProductVm.Concentration" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="MyAddProductVm.ImageUrl">Image</label>
            <input asp-for="MyAddProductVm.ImageUrl" class="form-input" type="file" accept=".jpg,.jpeg,.png,.webp" />
            <span asp-validation-for="MyAddProductVm.ImageUrl" class="text-danger"></span>
        </div>

        <div style="display:flex;gap:10px;margin-top:20px;">
            <button type="submit" class="btn btn-primary">Create Product</button>
            <a asp-action="Index" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}