@model PagedResult<ProductVM, ProductFilter, DashBoardProduct>
@using Perfum.Services.ViewModels.ProductVM
@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/_DashboardAdminLayOut.cshtml";
    var products = Model?.Items ?? new List<ProductVM>();
    var totalCount = Model?.TotalCount ?? 0;
    var inStock = products.Count(p => p.Stock > 10);
    var lowStock = products.Count(p => p.Stock > 0 && p.Stock <= 10);
    var outOfStock = products.Count(p => p.Stock == 0);
}

@* <link href="~/css/dashbord/product.css" rel="stylesheet" /> *@
<link href="~/css/dashbord/order.css" rel="stylesheet" />
<div class="product-page" >
    @* ── Header ── *@
    <div class="topbar">
        <div>
            <div class="page-title">Products <span>Catalogue</span></div>
            <div class="page-subtitle">@totalCount product@(totalCount == 1 ? "" : "s")</div>
        </div>
        <div class="topbar-actions">
            <button class="btn btn-ghost" onclick="showToast('Catalogue exported')">⬇ Export</button>
            <button class="btn btn-ghost" onclick="showToast('Import ready')">⬆ Import</button>
            <a asp-controller="Product" asp-action="Create" class="btn btn-primary">✦ Add Product</a>
        </div>
    </div>

    @* ── Stats ── *@
    <div class="stat-strip">
        <div class="mini-stat"><div class="mini-icon ic-amber">✨</div><div><div class="mini-val">@totalCount</div><div class="mini-label">Total Products</div></div></div>
        <div class="mini-stat"><div class="mini-icon ic-sage">📦</div><div><div class="mini-val">@inStock</div><div class="mini-label">In Stock</div></div></div>
        <div class="mini-stat"><div class="mini-icon ic-gold">⚠️</div><div><div class="mini-val">@lowStock</div><div class="mini-label">Low Stock</div></div></div>
        <div class="mini-stat"><div class="mini-icon ic-rose">⊘</div><div><div class="mini-val">@outOfStock</div><div class="mini-label">Out of Stock</div></div></div>
    </div>

    @* ── Toolbar ── *@
    <div class="toolbar">
        <div class="search-bar">
            <span style="color:var(--text3);font-size:16px">⌕</span>
            <input id="searchInput" placeholder="Search fragrances…" oninput="applyFilters()" />
        </div>
        <div class="filter-row" id="categoryChips"></div>
        <select class="sort-select" onchange="applyFilters()" id="sortSel" style="appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22><path fill=%22%23a08060%22 d=%22M0 0l5 6 5-6z%22/></svg>');background-repeat:no-repeat;background-position:right 12px center;padding-right:30px;">
            <option value="name">Name A–Z</option>
            <option value="price-asc">Price ↑</option>
            <option value="price-desc">Price ↓</option>
            <option value="stock">Stock</option>
        </select>
        <div class="view-toggle">
            <div class="view-btn active" id="gridViewBtn" onclick="switchView('grid')" title="Grid">⊞</div>
            <div class="view-btn" id="listViewBtn" onclick="switchView('list')" title="List">☰</div>
        </div>
    </div>

    @* ── Bulk actions ── *@
    <div class="bulk-bar" id="bulkBar">
        <div class="bulk-text">Selected: <strong id="bulkCount">0</strong></div>
        <button class="btn btn-ghost btn-sm" onclick="clearSelection()">Clear</button>
        <button class="btn btn-ghost btn-sm" onclick="showToast('Status updated')">Change Status</button>
        <button class="btn btn-danger btn-sm" onclick="bulkDelete()">✕ Delete</button>
    </div>

    @* ── Grid: all products ── *@
    <div class="prod-grid" id="prodGrid">
        @foreach (var p in products)
        {
            <div class="prod-card" data-id="@p.Id" data-search="@((p.Name + " " + (p.Descreption ?? "") + " " + (p.Concentration ?? "") + " " + (p.CategoryName ?? "")).ToLowerInvariant())" data-name="@p.Name" data-price="@p.Price" data-stock="@p.Stock">
                <div class="stock-badge @(p.Stock == 0 ? "sb-out" : p.Stock <= 10 ? "sb-low" : "sb-in")">
                    @(p.Stock == 0 ? "Out of Stock" : p.Stock <= 10 ? "Low Stock" : "In Stock")
                </div>
                <div class="prod-banner">
                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                    {
                        <img src="~/@p.ImageUrl" alt="@p.Name" style="max-width:100%;height:100%;" />
                    }
                    else
                    {
                        <span>🧴</span>
                    }
                </div>
                <div class="prod-body">
                    <div class="prod-category">@(p.Concentration ?? "—") · @p.Size_Ml ml</div>
                    <div class="prod-name">@p.Name</div>
                    <div class="prod-footer">
                        <div class="prod-price">$@p.Price.ToString("N2")</div>
                        <div class="prod-rating">Stock: @p.Stock</div>
                        <div>
                            <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-ghost btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-ghost btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-danger btn-sm">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
        @if (!products.Any())
        {
            <div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--text3)">No products found.</div>
        }
    </div>

    @* ── Table: all products ── *@
    <div class="table-wrap hidden" id="tableWrap">
        <table class="prod-table">
            <thead>
                <tr>
                    <th style="width:32px"><input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)" style="accent-color:var(--accent);cursor:pointer;width:15px;height:15px;" /></th>
                    <th onclick="setSortCol('name')">Product</th>
                    <th onclick="setSortCol('category')">Category</th>
                    <th onclick="setSortCol('price')">Price</th>
                    <th onclick="setSortCol('stock')">Stock</th>
                    <th onclick="setSortCol('status')">Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var p in products)
                {
                    <tr data-search="@((p.Name + " " + (p.Descreption ?? "") + " " + (p.Concentration ?? "") + " " + (p.CategoryName ?? "")).ToLowerInvariant())" data-name="@p.Name" data-price="@p.Price" data-stock="@p.Stock">
                        <td><input type="checkbox" style="accent-color:var(--accent);cursor:pointer;width:15px;height:15px;" /></td>
                        <td>
                            <div class="prod-identity">
                                <div class="prod-thumb">
                                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                                    {
                                        <img src="~/@p.ImageUrl" alt="@p.Name" style="width:100%;height:100%;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span>🧴</span>
                                    }
                                </div>
                                <div>
                                    <div class="pid-name">@p.Name</div>
                                    <div class="pid-sku">Category Id: @p.CategoryId</div>
                                </div>
                            </div>
                        </td>
                        <td>@p.CategoryId</td>
                        <td><span class="price-val">$@p.Price.ToString("N2")</span></td>
                        <td><span class="stock-num">@p.Stock</span></td>
                        <td>@(p.Stock == 0 ? "Out" : p.Stock <= 10 ? "Low" : "In Stock")</td>
                        <td></td>
                    </tr>
                }
                @if (!products.Any())
                {
                    <tr><td colspan="7" style="text-align:center;padding:48px;">No products found.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @* ── Pagination ── *@
    <div class="pagination">
        <div class="page-info" id="pageInfo">Showing 1–@Math.Min(12, totalCount) of @totalCount</div>
        <div class="page-btns">
            <div class="page-btn">‹</div>
            <div class="page-btn active">1</div>
            <div class="page-btn">›</div>
        </div>
    </div>
</div>

@* Pass all products to JS (for search/sort/filter if product.js uses it) *@
<script>
    window.productsFromServer = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products));
</script>

