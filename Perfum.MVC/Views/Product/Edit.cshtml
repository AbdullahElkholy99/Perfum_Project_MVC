@model Perfum.MVC.ViewModels.ProductEditPageVM
@using Perfum.Services.ViewModels.ProductVM
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_DashboardAdminLayOut.cshtml";
    SelectList CategoryItems = new SelectList(Model.Categories, "Id", "Name", Model.Product.CategoryId);
}
<link href="~/css/dashbord/product.css" rel="stylesheet" />
<div class="product-page">
    <div class="topbar">
        <div>
            <div class="page-title">Edit <span>Product</span></div>
        </div>
        <div class="topbar-actions">
            <a asp-action="Index" class="btn btn-ghost" style="text-decoration:none">Cancel</a>
        </div>
    </div>
    <form asp-action="Edit" asp-route-id="@ViewContext.RouteData.Values["id"]"
          method="post" enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Name</label>
            <input asp-for="Product.Name" class="form-input" />
            <span asp-validation-for="Product.Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Product.Descreption" class="form-input"></textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Price</label>
                <input asp-for="Product.Price" type="number" step="0.01" class="form-input" />
            </div>

            <div class="form-group">
                <label>Size (ml)</label>
                <input asp-for="Product.Size_Ml" type="number" step="0.01" class="form-input" />
            </div>
        </div>

        <div class="form-group">
            <label>Concentration</label>
            <input asp-for="Product.Concentration" class="form-input" />
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Stock</label>
                <input asp-for="Product.Stock" type="number" class="form-input" />
            </div>

            <div class="form-group">
                <label>Category</label>
                <select asp-for="Product.CategoryId"
                        class="form-input"
                        asp-items="@CategoryItems">
                    <option value="">-- Select --</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label>New Image</label>
            <input asp-for="Product.ImageUrl" type="file" class="form-input" />
        </div>

        <button type="submit" class="btn btn-primary">Save Changes</button>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}