@using Perfum.Services.ViewModels.CategoryVM
@model CategoryVM

@{
    ViewData["Title"] = "Delete Category";
    Layout = "~/Views/Shared/_DashboardAdminLayOut.cshtml";
}

<div class="product-page">
    <div class="topbar">
        <div>
            <div class="page-title">Delete <span>Category</span></div>
            <div class="page-subtitle">@Model.Name</div>
        </div>
        <div class="topbar-actions">
            <a asp-action="Index" class="btn btn-ghost">Back to list</a>
        </div>
    </div>

    <div style="background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:20px;">
        <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
        <p class="text-muted">@Model.Description</p>
    </div>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
    </form>
</div>
