    <section class="hero verify-email-hero">

        <div class="verify-box">

            <h1 class="hero-title verify-title">
                Verify <em>Email</em>
            </h1>

            <p class="hero-sub verify-sub">
                We sent a 6-digit code to
                <strong>@Model.Email</strong>.
                Check your inbox (and spam folder).
            </p>

            @if (TempData["VerifyEmailMessage"] != null)
            {
                <div class="auth-msg auth-error">
                    @TempData["VerifyEmailMessage"]
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="auth-msg auth-error"></div>

            <form asp-action="VerifyEmailConfirmation"
                  asp-controller="Account"
                  method="post"
                  class="auth-form verify-form">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Email" />

                <div class="auth-input-wrap">

                    <label asp-for="Code" class="auth-label">
                        Verification Code
                    </label>

                    <input asp-for="Code"
                           id="verifyCode"
                           type="text"
                           class="auth-input verify-code-input"
                           placeholder="000000"
                           maxlength="6"
                           autocomplete="one-time-code" />

                    <span asp-validation-for="Code" class="auth-validation"></span>

                </div>

                <button type="submit" class="hero-cta verify-btn">
                    Verify Email
                </button>

                <a asp-action="Login"
                       asp-controller="Account"
                       class="auth-link verify-back">
                    Back to Sign In
                </a>

            </form>

        </div>

    </section>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>


<script>

const codeInput = document.getElementById("verifyCode");

codeInput.addEventListener("input", function () {

    this.value = this.value.replace(/[^0-9]/g, '');

});

codeInput.addEventListener("paste", function (e) {

    let paste = (e.clipboardData || window.clipboardData).getData('text');

    if(paste.length === 6){
        this.value = paste;
    }

});

</script>
</body>
