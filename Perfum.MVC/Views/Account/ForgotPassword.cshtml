@model ForgotPasswordVM

@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password — Sillage</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="~/css/auth/forgotpassword.css" rel="stylesheet" />
</head>
<body>

    <section class="hero" style="min-height:60vh;display:flex;align-items:center;justify-content:center;">
        <div style="width:100%;max-width:420px;padding:0 24px;">
            <h1 class="hero-title" style="font-size:28px;text-align:center;margin-bottom:8px;">Forgot <em>Password</em></h1>
            <p class="hero-sub" style="text-align:center;margin-bottom:32px;">Enter your email and we will send you a verification code.</p>

            @if (TempData["VerifyCodeMessage"] != null)
            {
                <div class="auth-msg auth-error">@TempData["VerifyCodeMessage"]</div>
            }
            <div asp-validation-summary="ModelOnly" class="auth-msg auth-error"></div>

            <form asp-action="ForgotPassword" asp-controller="Account" method="post" class="auth-form">
                @Html.AntiForgeryToken()

                <div class="auth-input-wrap">
                    <label asp-for="Email" class="auth-label">Email</label>
                    <input asp-for="Email" type="email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="auth-validation"></span>
                </div>

                <button type="submit" class="hero-cta" style="width:100%;justify-content:center;margin-bottom:16px;">Send Code</button>
                <a asp-action="Login" asp-controller="Account" class="auth-link" style="display:block;text-align:center;">Back to Sign In</a>
            </form>
        </div>
    </section>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>

