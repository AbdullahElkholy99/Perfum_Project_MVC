@model ForgotPasswordVM

@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password — Sillage</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    @* <link href="~/css/auth/forgotpassword.css" rel="stylesheet" /> *@

    <style>
            .auth-section {
                min-height: 60vh;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 60px 20px;
            }

            .auth-box {
                width: 100%;
                max-width: 420px;
                background: #fff;
                padding: 40px;
                border-radius: 12px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            }

                .auth-box h1 {
                    font-size: 28px;
                    text-align: center;
                    margin-bottom: 10px;
                }

                    .auth-box h1 span {
                        color: #7a9e7e;
                    }

                .auth-box p {
                    text-align: center;
                    color: #777;
                    font-size: 14px;
                    margin-bottom: 30px;
                }

            .form-group {
                margin-bottom: 20px;
            }

                .form-group label {
                    display: block;
                    font-size: 14px;
                    margin-bottom: 6px;
                    color: #333;
                }

                .form-group input {
                    width: 100%;
                    padding: 12px;
                    border: 1px solid #ddd;
                    border-radius: 6px;
                    font-size: 14px;
                }

            .btn-submit {
                width: 100%;
                padding: 12px;
                background: #7a9e7e;
                border: none;
                color: #fff;
                font-size: 15px;
                border-radius: 6px;
                cursor: pointer;
                transition: 0.3s;
            }

                .btn-submit:hover {
                    background: #5f8463;
                }

            .auth-footer {
                text-align: center;
                margin-top: 20px;
            }

                .auth-footer a {
                    font-size: 14px;
                    color: #7a9e7e;
                    text-decoration: none;
                }
    </style>
</head>
<body>

    @* <section class="hero" style="min-height:60vh;display:flex;align-items:center;justify-content:center;">
        <div style="width:100%;max-width:420px;padding:0 24px;">
            <h1 class="hero-title" style="font-size:28px;text-align:center;margin-bottom:8px;">Forgot <em>Password</em></h1>
            <p class="hero-sub" style="text-align:center;margin-bottom:32px;">Enter your email and we will send you a verification code.</p>

            @if (TempData["VerifyCodeMessage"] != null)
            {
                <div class="auth-msg auth-error">@TempData["VerifyCodeMessage"]</div>
            }
            <div asp-validation-summary="ModelOnly" class="auth-msg auth-error"></div>

            <form asp-action="ForgotPassword" asp-controller="Account" method="post" class="auth-form">
                @Html.AntiForgeryToken()

                <div class="auth-input-wrap">
