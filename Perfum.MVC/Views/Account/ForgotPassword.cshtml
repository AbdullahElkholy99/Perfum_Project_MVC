 *@

@model ForgotPasswordVM
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password — Sillage</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="~/css/users/login.css" rel="stylesheet" />
    <style>
        /* ── Forgot-password specific ── */

        /* Centered single-column layout on right panel */
        .fp-icon-wrap {
            width: 64px;
            height: 64px;
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(200,133,74,.12), rgba(212,168,68,.08));
            border: 1px solid rgba(200,133,74,.22);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            animation: fadeSlideUp .7s ease-out .05s both;
        }

            .fp-icon-wrap i {
                font-size: 26px;
                background: linear-gradient(135deg, var(--accent), var(--gold));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            /* Animated ring around icon */
            .fp-icon-wrap::before {
                content: '';
                position: absolute;
                width: 86px;
                height: 86px;
                border-radius: 24px;
                border: 1px solid rgba(200,133,74,.12);
                animation: ringPulse 3s ease-in-out infinite;
            }

            .fp-icon-wrap::after {
                content: '';
                position: absolute;
                width: 110px;
                height: 110px;
                border-radius: 30px;
                border: 1px solid rgba(200,133,74,.07);
                animation: ringPulse 3s ease-in-out infinite .5s;
            }
        @@keyframes ringPulse {
            0%, 100% {
                transform: scale(1);
                opacity: 1;
            }

            50% {
                transform: scale(1.06);
                opacity: .5;
            }
        }

        /* Steps hint */
        .fp-steps {
            display: flex;
            gap: 10px;
            margin-bottom: 32px;
            animation: fadeSlideUp .6s ease-out .2s both;
        }

        .fp-step-chip {
            flex: 1;
            padding: 10px 8px;
            border-radius: 10px;
            background: var(--bg);
            border: 1px solid var(--border);
            text-align: center;
            transition: all .3s;
        }

            .fp-step-chip.active {
                background: linear-gradient(135deg, rgba(200,133,74,.10), rgba(212,168,68,.06));
                border-color: rgba(200,133,74,.30);
            }

        .fp-step-chip-num {
            font-size: 15px;
            font-family: 'Cormorant Garamond', serif;
            font-weight: 600;
            color: var(--text3);
            display: block;
            line-height: 1;
            margin-bottom: 4px;
        }

        .fp-step-chip.active .fp-step-chip-num {
            color: var(--accent);
        }

        .fp-step-chip-label {
            font-size: 8px;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--text3);
        }

        .fp-step-chip.active .fp-step-chip-label {
            color: var(--accent);
        }

        /* Success state */
        .fp-success {
            display: none;
            text-align: center;
            animation: fadeSlideUp .5s ease-out both;
        }

            .fp-success.show {
                display: block;
            }

        .fp-success-icon {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: var(--ok-bg);
            border: 1px solid rgba(122,158,126,.3);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 24px;
            color: var(--green);
        }

        .fp-success-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 26px;
            font-weight: 300;
            color: var(--text);
            margin-bottom: 10px;
        }

            .fp-success-title em {
                font-style: italic;
                color: var(--green);
            }

        .fp-success-body {
            font-size: 13px;
            color: var(--text2);
            letter-spacing: .04em;
            line-height: 1.8;
            margin-bottom: 28px;
            max-width: 300px;
            margin-left: auto;
            margin-right: auto;
        }

        .fp-success-email {
            font-weight: 500;
            color: var(--accent);
        }

        /* Resend timer */
        .fp-resend {
            font-size: 12px;
            color: var(--text3);
            letter-spacing: .05em;
            margin-top: 16px;
            text-align: center;
        }

        .fp-resend-link {
            color: var(--accent);
            cursor: pointer;
            border-bottom: 1px solid transparent;
            transition: all .2s;
            display: none;
        }

            .fp-resend-link.visible {
                display: inline;
            }

            .fp-resend-link:hover {
                border-bottom-color: var(--accent);
            }

        /* Decorative particles on the right */
        .fp-particles {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .fp-particle {
            position: absolute;
            border-radius: 50%;
            background: var(--accent);
            opacity: 0;
            animation: particleDrift ease-in-out infinite;
        }
        @@keyframes particleDrift {
            0% {
                transform: translateY(0) scale(1);
                opacity: 0;
            }

            20% {
                opacity: .12;
            }

            80% {
                opacity: .06;
            }

            100% {
                transform: translateY(-120px) scale(.4);
                opacity: 0;
            }
        }
    </style>
</head>
<body>

    <div class="login-page">

        <!-- ══════════════════════════════════
             LEFT — Brand Panel
        ══════════════════════════════════ -->
        <div class="login-brand">
            <div class="lb-orb lb-orb-1"></div>
            <div class="lb-orb lb-orb-2"></div>
            <div class="lb-orb lb-orb-3"></div>
            <div class="lb-grain"></div>
            <div class="lb-mist" id="lbMist"></div>
            <div class="lb-rule"></div>

            <div class="lb-content">
                <div class="lb-logo">Sill<em>age</em><span class="lb-logo-sub">Luxury Fragrance Studio</span></div>

                <div class="lb-bottle">
                    <svg width="130" height="280" viewBox="0 0 160 340" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="lbBodyGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="0%" stop-color="#c8854a" stop-opacity=".20" />
                                <stop offset="30%" stop-color="rgba(255,245,235,1)" stop-opacity=".90" />
                                <stop offset="70%" stop-color="rgba(255,248,240,1)" stop-opacity=".95" />
                                <stop offset="100%" stop-color="#c8854a" stop-opacity=".30" />
                            </linearGradient>
                            <linearGradient id="lbCapGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="0%" stop-color="#9b6b3a" />
                                <stop offset="50%" stop-color="#d4a844" />
                                <stop offset="100%" stop-color="#9b6b3a" />
                            </linearGradient>
                            <linearGradient id="lbLiquidGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" stop-color="#d4a844" stop-opacity=".55" />
                                <stop offset="100%" stop-color="#c8854a" stop-opacity=".80" />
                            </linearGradient>
                            <clipPath id="lbBodyClip"><rect x="24" y="118" width="112" height="200" rx="14" /></clipPath>
                        </defs>
                        <rect x="56" y="18" width="48" height="52" rx="6" fill="url(#lbCapGrad)" />
                        <rect x="60" y="22" width="40" height="44" rx="4" fill="url(#lbCapGrad)" opacity=".55" />
                        <rect x="54" y="66" width="52" height="4" rx="2" fill="#9b6b3a" opacity=".5" />
                        <rect x="62" y="70" width="36" height="50" rx="4" fill="rgba(255,235,210,.7)" />
                        <rect x="58" y="112" width="44" height="8" rx="4" fill="url(#lbCapGrad)" opacity=".65" />
                        <rect x="24" y="118" width="112" height="200" rx="14" fill="url(#lbBodyGrad)" stroke="rgba(212,168,68,.30)" stroke-width="1" />
                        <rect x="24" y="200" width="112" height="118" fill="url(#lbLiquidGrad)" clip-path="url(#lbBodyClip)" opacity=".42" />
                        <ellipse cx="80" cy="200" rx="50" ry="5" fill="rgba(255,220,150,.38)" opacity=".8" />
                        <rect x="38" y="148" width="84" height="90" rx="8" fill="white" opacity=".68" />
                        <text x="80" y="176" text-anchor="middle" font-family="Cormorant Garamond,serif" font-size="11" fill="#2a1f14" opacity=".75" letter-spacing="1.5">SILLAGE</text>
                        <line x1="50" y1="181" x2="110" y2="181" stroke="rgba(200,133,74,.45)" stroke-width=".8" />
                        <text x="80" y="197" text-anchor="middle" font-family="Jost,sans-serif" font-size="7" fill="#6b5040" opacity=".65" letter-spacing="2.5">PARFUM</text>
                        <text x="80" y="216" text-anchor="middle" font-family="Cormorant Garamond,serif" font-size="18" fill="#c8854a" opacity=".88" font-style="italic">Obscura</text>
                        <text x="80" y="228" text-anchor="middle" font-family="Jost,sans-serif" font-size="6" fill="#a08060" opacity=".55" letter-spacing="3">100 ML · EDP</text>
                        <rect x="32" y="130" width="6" height="160" rx="3" fill="white" opacity=".22" />
                        <rect x="42" y="130" width="2" height="140" rx="1" fill="white" opacity=".10" />
                        <rect x="20" y="314" width="120" height="10" rx="5" fill="url(#lbCapGrad)" opacity=".55" />
                        <rect x="16" y="320" width="128" height="6" rx="3" fill="#9b6b3a" opacity=".38" />
                    </svg>
                </div>

                <p class="lb-tagline">Your scent awaits.<br>Let us help you back in.</p>

                <div class="lb-dots">
                    <div class="lb-dot"></div>
                    <div class="lb-dot"></div>
                    <div class="lb-dot"></div>
                </div>
            </div>

            <div class="lb-badges">
                <div class="lb-badge"><div class="lb-badge-dot"></div>Secure Reset</div>
                <div class="lb-badge"><div class="lb-badge-dot"></div>Code expires in 15 min</div>
                <div class="lb-badge"><div class="lb-badge-dot"></div>No spam, ever</div>
            </div>
        </div>

        <!-- ══════════════════════════════════
             RIGHT — Form Panel
        ══════════════════════════════════ -->
        <div class="login-form-panel">

            <!-- Drifting particles -->
            <div class="fp-particles" id="fpParticles"></div>

            <a asp-action="Login" asp-controller="Account" class="auth-back">
                <i class="fa-solid fa-arrow-left"></i> Sign In
            </a>

            <div class="auth-theme-btn" onclick="toggleAuthTheme()" id="authThemeBtn" title="Toggle theme">
                <i class="fa-solid fa-moon"></i>
            </div>

            <div class="login-form-wrap">

                <!-- Icon -->
                <div class="fp-icon-wrap">
                    <i class="fa-regular fa-envelope-open"></i>
                </div>

                <!-- Header -->
                <div class="auth-eyebrow" style="animation: fadeSlideUp .6s ease-out .1s both;">
                    <div class="auth-eyebrow-line"></div>
                    <span>Password Recovery</span>
                    <div class="auth-eyebrow-line"></div>
                </div>
                <h1 class="auth-title" style="animation: fadeSlideUp .6s ease-out .15s both;">
                    Forgot <em>Password</em>
                </h1>
                <p class="auth-subtitle" style="animation: fadeSlideUp .6s ease-out .2s both;">
                    Enter your email and we'll send you a verification code to reset your password.
                </p>

                <!-- Step chips -->
                <div class="fp-steps">
                    <div class="fp-step-chip active">
                        <span class="fp-step-chip-num">01</span>
                        <span class="fp-step-chip-label">Enter Email</span>
                    </div>
                    <div class="fp-step-chip">
                        <span class="fp-step-chip-num">02</span>
                        <span class="fp-step-chip-label">Verify Code</span>
                    </div>
                    <div class="fp-step-chip">
                        <span class="fp-step-chip-num">03</span>
                        <span class="fp-step-chip-label">New Password</span>
                    </div>
                </div>

                <!-- Server messages -->
                @if (TempData["VerifyCodeMessage"] != null)
                {
                    <div class="auth-msg auth-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        @TempData["VerifyCodeMessage"]
                    </div>
                }
                <div asp-validation-summary="ModelOnly" class="auth-msg auth-error"></div>

                <!-- ── Form ── -->
                <form asp-action="ForgotPassword" asp-controller="Account" method="post" id="fpForm" style="animation: fadeSlideUp .6s ease-out .28s both;">
                    @Html.AntiForgeryToken()

                    <div class="auth-input-wrap">
                        <label asp-for="Email" class="auth-label">Email Address</label>
                        <div class="auth-input-inner">
                            <input asp-for="Email"
                                   type="email"
                                   class="auth-input"
                                   placeholder="you@example.com"
                                   autocomplete="email"
                                   id="fpEmail" />
                            <i class="fa-regular fa-envelope auth-input-icon"></i>
                        </div>
                        <span asp-validation-for="Email" class="auth-validation"></span>
                    </div>

                    <button type="submit" class="auth-submit" id="fpSubmit" onclick="handleSubmit(this)">
                        <span class="btn-text">
                            Send Reset Code &nbsp;
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                <path d="M2 8h12M9 4l5 4-5 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    </button>
                </form>

                <!-- ── Success state (shown by JS after submit demo) ── -->
                <div class="fp-success" id="fpSuccess">
                    <div class="fp-success-icon">
                        <i class="fa-solid fa-paper-plane"></i>
                    </div>
                    <p class="fp-success-title">Check your <em>Inbox</em></p>
                    <p class="fp-success-body">
                        We've sent a verification code to<br>
                        <span class="fp-success-email" id="fpSuccessEmail"></span>.<br>
                        It expires in 15 minutes.
                    </p>
                    <a asp-action="VerifyEmailConfirmation" asp-controller="Account" class="auth-submit" style="text-decoration:none;display:flex;">
                        <span class="btn-text">Enter Verification Code &nbsp;<i class="fa-solid fa-key" style="font-size:12px"></i></span>
                    </a>
                    <p class="fp-resend">
                        Didn't receive it?
                        <span class="fp-resend-link" id="fpResendLink" onclick="resendCode()">Resend code</span>
                        <span id="fpTimer">Resend in <strong id="fpCountdown">60</strong>s</span>
                    </p>
                </div>

                <!-- Back link -->
                <div style="text-align:center;margin-top:20px;animation: fadeSlideUp .6s ease-out .36s both;">
                    <a asp-action="Login" asp-controller="Account" class="auth-link">
                        <i class="fa-solid fa-arrow-left" style="font-size:10px;margin-right:4px;"></i>
                        Back to Sign In
                    </a>
                </div>

            </div><!-- /login-form-wrap -->
        </div><!-- /login-form-panel -->

    </div><!-- /login-page -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        /* ── Theme ── */
        let authDark = false;
        function toggleAuthTheme() {
            authDark = !authDark;
            document.documentElement.setAttribute('data-theme', authDark ? 'dark' : 'light');
            document.getElementById('authThemeBtn').innerHTML = authDark
                ? '<i class="fa-solid fa-sun"></i>'
                : '<i class="fa-solid fa-moon"></i>';
        }

        /* ── Submit loading ── */
        function handleSubmit(btn) {
            const email = document.getElementById('fpEmail').value.trim();
            if (!email) return;
            setTimeout(() => {
                const form = document.getElementById('fpForm');
                if (form.checkValidity()) btn.classList.add('loading');
            }, 50);
        }

        /* ── Mist lines ── */
        (function () {
            const c = document.getElementById('lbMist');
            if (!c) return;
            for (let i = 0; i < 14; i++) {
                const el = document.createElement('div');
                el.className = 'lb-mist-line';
                const l = Math.random() * 100, h = 70 + Math.random() * 180;
                const d = 10 + Math.random() * 14, dl = -(Math.random() * d);
                el.style.cssText = `left:${l}%;height:${h}px;animation-duration:${d}s;animation-delay:${dl}s;`;
                c.appendChild(el);
            }
        })();

        /* ── Drifting particles (right panel) ── */
        (function () {
            const c = document.getElementById('fpParticles');
            if (!c) return;
            for (let i = 0; i < 10; i++) {
                const el = document.createElement('div');
                el.className = 'fp-particle';
                const size = 3 + Math.random() * 6;
                const left = 10 + Math.random() * 80;
                const top  = 20 + Math.random() * 70;
                const dur  = 6 + Math.random() * 8;
                const del  = -(Math.random() * dur);
                el.style.cssText = `width:${size}px;height:${size}px;left:${left}%;top:${top}%;animation-duration:${dur}s;animation-delay:${del}s;`;
                c.appendChild(el);
            }
        })();

        /* ── Bottle parallax ── */
        const bp = document.querySelector('.login-brand');
        const bt = document.querySelector('.lb-bottle');
        if (bp && bt) {
            bp.addEventListener('mousemove', e => {
                const r  = bp.getBoundingClientRect();
                const dx = (e.clientX - r.left - r.width  / 2) / (r.width  / 2);
                const dy = (e.clientY - r.top  - r.height / 2) / (r.height / 2);
                bt.style.transform = `translateY(0) rotate(${dx * 4}deg) rotateX(${-dy * 3}deg)`;
            });
            bp.addEventListener('mouseleave', () => { bt.style.transform = ''; });
        }

        /* ── Resend countdown ── */
        let countdownTimer;
        function startCountdown(sec) {
            const el   = document.getElementById('fpCountdown');
            const wrap = document.getElementById('fpTimer');
            const link = document.getElementById('fpResendLink');
            link.classList.remove('visible');
            wrap.style.display = 'inline';
            clearInterval(countdownTimer);
            countdownTimer = setInterval(() => {
                el.textContent = --sec;
                if (sec <= 0) {
                    clearInterval(countdownTimer);
                    wrap.style.display = 'none';
                    link.classList.add('visible');
                }
            }, 1000);
        }
        function resendCode() {
            document.getElementById('fpResendLink').classList.remove('visible');
            startCountdown(60);
            // Trigger actual form re-submit here if desired
        }
    </script>
</body>
</html>
