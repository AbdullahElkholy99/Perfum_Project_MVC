 *@
    <section class="auth-section">
        <div class="auth-box">

            <h1>Forgot <span>Password</span></h1>
            <p>Enter your email address and we will send you a password reset link.</p>

            <form asp-action="ForgotPassword" asp-controller="Account" method="post" class="auth-form">
                    @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Email" class="auth-label">Email</label>
                    <input asp-for="Email" type="email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="auth-validation"></span>
                </div>

                <button type="submit" class="btn-submit">
                    Send Reset Link
                </button>

    
            </form>

            <div class="auth-footer">
                <a asp-action="Login" asp-controller="Account"  >Back to Sign In</a>
            </div>

        </div>
    </section>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>

