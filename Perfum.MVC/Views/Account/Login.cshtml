@model LoginVM
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In — Sillage</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="~/css/users/customerpage.css" rel="stylesheet" />
    <link href="~/css/auth/auth.css" rel="stylesheet" />
</head>
<body>
    <nav>
        <div class="nav-inner">
            <a asp-controller="Home" asp-action="Index" style="text-decoration:none" class="nav-logo">Sill<span>age</span></a>
            <div class="nav-links" style="margin-left:auto;display:flex;align-items:center;gap:24px;">
                <a asp-controller="Home" asp-action="Index" style="text-decoration:none" class="nav-link">Home</a>
                @await Html.PartialAsync("_AuthNavPartial")
            </div>
        </div>
    </nav>

    <section class="hero" style="min-height:60vh;display:flex;align-items:center;justify-content:center;">
        <div style="width:100%;max-width:420px;padding:0 24px;">
            <h1 class="hero-title" style="font-size:28px;text-align:center;margin-bottom:8px;">Sign <em>In</em></h1>
            <p class="hero-sub" style="text-align:center;margin-bottom:32px;">Welcome back to Sillage</p>

            @if (TempData["RegisterSuccess"] != null)
            {
                <div class="auth-msg auth-success">@TempData["RegisterSuccess"]</div>
            }
            <div asp-validation-summary="ModelOnly" class="auth-msg auth-error"></div>
            @if (ViewBag.RequiresEmailConfirmation == true && Model != null)
            {
                <p style="margin-bottom:16px;">
                    <a asp-action="VerifyEmailConfirmation" asp-controller="Account" asp-route-email="@Model.?Email" class="auth-link">Enter your verification code</a>
                </p>
            }

            <form asp-action="Login" asp-controller="Account" method="post" class="auth-form">
                @Html.AntiForgeryToken()

                <div class="auth-input-wrap">
                    <label asp-for="Email" class="auth-label">Email</label>
                    <input asp-for="Email" type="email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="auth-validation"></span>
                </div>

                <div class="auth-input-wrap">
                    <label asp-for="Password" class="auth-label">Password</label>
                    <input asp-for="Password" type="password" class="auth-input" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="auth-validation"></span>
                </div>

                <div class="auth-row" style="justify-content:space-between;margin-bottom:24px;">
                    <label class="auth-check">
                        <input asp-for="RememberMe" type="checkbox" />
                        <span>Remember me</span>
                    </label>
                    <a asp-action="ForgotPassword" asp-controller="Account" class="auth-link">Forgot password?</a>
                </div>

                <button type="submit" class="hero-cta btn" style="width:100%;justify-content:center;margin-bottom:16px;">Sign In</button>
            </form>

            <form asp-action="GoogleLogin" asp-controller="Account" method="post" style="margin-top:8px;">
                @Html.AntiForgeryToken()
                <button type="submit" class="hero-cta btn" style="width:100%;justify-content:center;background-color:white;color:#444;border:1px solid #ddd;gap:8px;">
                    <i class="fa-brands fa-google"></i>
                    Continue with Google
                </button>
            </form>

            <p class="auth-switch">
                Don't have an account? <a asp-action="Register" asp-controller="Account" class="auth-link">Sign Up</a>
            </p>
        </div>
    </section>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
