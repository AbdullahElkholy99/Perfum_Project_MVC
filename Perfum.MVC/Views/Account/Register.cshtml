@model RegisterVM
@{
    Layout = null;
    ViewData["Title"] = "Sign Up";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up — Sillage</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="~/css/users/customerpage.css" rel="stylesheet" />
    <link href="~/css/auth/auth.css" rel="stylesheet" />
</head>
<body>
  @*   <nav>
        <div class="nav-inner">
            <a asp-controller="Home" asp-action="Index" class="nav-logo">Sill<span>age</span></a>
            <div class="nav-links" style="margin-left:auto;display:flex;align-items:center;gap:24px;">
                <a asp-controller="Home" asp-action="Index" class="nav-link">Home</a>
                @await Html.PartialAsync("_AuthNavPartial")
            </div>
        </div>
    </nav>
 *@
    <section class="hero" style="min-height:auto;padding:80px 24px 120px;">
        <div style="width:100%;max-width:420px;margin:0 auto;">
            <h1 class="hero-title" style="font-size:28px;text-align:center;margin-bottom:8px;">Create <em>Account</em></h1>
            <p class="hero-sub" style="text-align:center;margin-bottom:32px;">Join Sillage — Luxury Fragrance Studio</p>

            <div asp-validation-summary="ModelOnly" class="auth-msg auth-error"></div>

            <form asp-action="Register" asp-controller="Account" method="post" class="auth-form">
                @Html.AntiForgeryToken()

                <div class="auth-input-wrap">
                    <label asp-for="UserName" class="auth-label">Username</label>
                    <input asp-for="UserName" type="text" class="auth-input" placeholder="Your username" autocomplete="username" />
                    <span asp-validation-for="UserName" class="auth-validation"></span>
                </div>

                <div class="auth-input-wrap">
                    <label asp-for="Email" class="auth-label">Email</label>
                    <input asp-for="Email" type="email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="auth-validation"></span>
                </div>

                <div class="auth-input-wrap">
                    <label asp-for="Password" class="auth-label">Password</label>
                    <input asp-for="Password" type="password" class="auth-input" placeholder="••••••••" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="auth-validation"></span>
                </div>

                <div class="auth-input-wrap">
                    <label asp-for="ConfirmPassword" class="auth-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="auth-input" placeholder="••••••••" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="auth-validation"></span>
                </div>

                <div class="auth-input-wrap">
                    <label asp-for="PhoneNumber" class="auth-label">Phone Number</label>
                    <input asp-for="PhoneNumber" type="tel" class="auth-input" placeholder="+20 1012345678" autocomplete="tel" />
                    <span asp-validation-for="PhoneNumber" class="auth-validation"></span>
                </div>

                <div class="auth-input-wrap">
                    <label asp-for="Address" class="auth-label">Address</label>
                    <input asp-for="Address" type="text" class="auth-input" placeholder="Your address" autocomplete="street-address" />
                    <span asp-validation-for="Address" class="auth-validation"></span>
                </div>

                <button type="submit" class="hero-cta" style="width:100%;justify-content:center;margin-top:8px;margin-bottom:16px;">Create Account</button>
            </form>

            <form asp-action="GoogleLogin" asp-controller="Account" method="post" style="margin-top:8px;">
                @Html.AntiForgeryToken()
                <button type="submit" class="hero-cta btn" style="width:100%;justify-content:center;background-color:white;color:#444;border:1px solid #ddd;gap:8px;">
                    <i class="fa-brands fa-google"></i>
                    Continue with Google
                </button>
            </form>

            <p class="auth-switch">
                Already have an account? <a asp-action="Login" asp-controller="Account" class="auth-link">Sign In</a>
            </p>
        </div>
    </section>

   @*  <footer>
        <div class="footer-logo">Sillage</div>
        <div class="footer-tagline">Luxury Fragrance Studio · Est. 2018</div>
    </footer> *@

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
