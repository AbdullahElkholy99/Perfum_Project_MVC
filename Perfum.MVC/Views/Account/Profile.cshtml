          </div>
          <div class="notif-item">
            <div class="notif-icon">✦</div>
            <div class="notif-info">
              <div class="notif-title">New Arrivals & Collections</div>
              <div class="notif-desc">Be the first to discover new fragrances and seasonal launches</div>
            </div>
            <label class="toggle-wrap"><input type="checkbox" checked><span class="toggle-slider"></span></label>
          </div>
          <div class="notif-item">
            <div class="notif-icon">🎁</div>
            <div class="notif-info">
              <div class="notif-title">Exclusive Offers & Promotions</div>
              <div class="notif-desc">Member-only discounts, gift-with-purchase, and seasonal sales</div>
            </div>
            <label class="toggle-wrap"><input type="checkbox"><span class="toggle-slider"></span></label>
          </div>
          <div class="notif-item">
            <div class="notif-icon">💛</div>
            <div class="notif-info">
              <div class="notif-title">Wishlist Restocks</div>
              <div class="notif-desc">Get notified when a wishlisted item is back in stock</div>
            </div>
            <label class="toggle-wrap"><input type="checkbox" checked><span class="toggle-slider"></span></label>
          </div>
          <div class="notif-item">
            <div class="notif-icon">📖</div>
            <div class="notif-info">
              <div class="notif-title">The Sillage Journal</div>
              <div class="notif-desc">Stories from the atelier, perfumer diaries, and fragrance guides</div>
            </div>
            <label class="toggle-wrap"><input type="checkbox" checked><span class="toggle-slider"></span></label>
          </div>
