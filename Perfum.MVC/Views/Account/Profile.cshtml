    </main>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast">
    <div class="toast-dot"></div>
    <span id="toastMsg">Saved</span>
  </div>

  <script>
    /* ── THEME ── */
    let dark = false;
    function toggleTheme() {
      dark = !dark;
      document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
      document.getElementById('themeBtn').textContent = dark ? '☀️' : '🌙';
    }

    /* ── TAB SWITCHING ── */
    function showTab(id, navEl) {
      document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
      document.getElementById('tab-' + id).style.display = 'block';
      document.querySelectorAll('.snav-item').forEach(n => n.classList.remove('active'));
      navEl.classList.add('active');
    }

    /* ── TOAST ── */
    let toastTimer;
    function showToast(msg) {
      const t = document.getElementById('toast');
      document.getElementById('toastMsg').textContent = msg;
      t.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
    }

    /* ── PASSWORD TOGGLE ── */
    function togglePw(id, icon) {
      const inp = document.getElementById(id);
      const show = inp.type === 'password';
      inp.type = show ? 'text' : 'password';
      icon.innerHTML = show ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
    }

    /* ── SAVE PROFILE ── */
    function saveProfile() {
      const s = document.getElementById('saveStatus');
      s.classList.add('show');
      showToast('Profile saved successfully ✦');
      setTimeout(() => s.classList.remove('show'), 3000);
    }

    /* ── SCENT TAGS ── */
    function toggleTag(el) {
      el.classList.toggle('selected');
    }

    /* ── INTENSITY ── */
    const intensityNames = ['', 'Very Light', 'Light', 'Medium', 'Strong', 'Intense'];
    function setIntensity(n) {
      document.querySelectorAll('.si-step').forEach((s, i) => {
        s.classList.toggle('on', i < n);
      });
      document.getElementById('intensityLabel').textContent = intensityNames[n];
    }
  </script>
</body>
</html>

